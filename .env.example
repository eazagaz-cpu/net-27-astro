# ============================================
# NetMirror API Configuration
# ============================================

# TMDB (Required - Primary metadata/images)
TMDB_API_KEY=your_tmdb_api_key
PUBLIC_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p

# OMDb (Optional - IMDb/RT/Metacritic ratings)
OMDB_API_KEY=your_omdb_api_key

# YouTube Data API (Optional - Official trailers)
YOUTUBE_API_KEY=your_youtube_api_key

# TVmaze (Optional - TV episode data)
TVMAZE_API_KEY=your_tvmaze_api_key

# Watchmode (Optional - Streaming availability)
WATCHMODE_API_KEY=your_watchmode_api_key

# RapidAPI Streaming Availability (Optional - official provider deep links)
RAPIDAPI_STREAMING_KEY=your_rapidapi_key

# Firebase (Optional - Google Sign-In)
PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your_project_id
PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Stream API (Optional - Additional player servers)
STREAM_API_BASE_URL=
STREAM_API_TOKEN=
