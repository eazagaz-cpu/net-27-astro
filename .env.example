# Firebase Configuration (required for Google Sign-In)
PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=your_project_id
PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# TMDB API (required for auto-updating content)
# Get from https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key
PUBLIC_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p

# Optional: Legal streaming source API
STREAM_API_BASE_URL=
STREAM_API_TOKEN=

# Optional: Debug mode
PUBLIC_ENABLE_DEBUG=false
