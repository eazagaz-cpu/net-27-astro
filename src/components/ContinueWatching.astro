---
// Client-side only — reads localStorage 'netmirror:history', renders nothing if empty
---

<div id="cw-rail-section" style="display:none;padding:1rem 0">
  <div style="max-width:1400px;margin:0 auto;padding:0 1rem">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
      <div style="display:flex;align-items:center;gap:0.5rem">
        <h2 class="section-title">Continue Watching</h2>
        <span style="font-size:10px;font-weight:700;padding:2px 6px;border-radius:4px;background:var(--color-primary);color:#fff;text-transform:uppercase;letter-spacing:0.05em">
          NEW
        </span>
      </div>
      <button id="cw-clear-btn" style="font-size:12px;color:#71717a;background:none;border:none;cursor:pointer;padding:4px 8px;border-radius:6px" onmouseenter="this.style.color='#ef4444'" onmouseleave="this.style.color='#71717a'">Clear</button>
    </div>
    <div class="rail-wrap" style="position:relative">
      <div id="cw-scroll" class="scroll-rail"></div>
    </div>
  </div>
</div>

<script>
  const CW_KEY = 'netmirror:history';
  function getCW(): any[] { try { return JSON.parse(localStorage.getItem(CW_KEY) || '[]'); } catch { return []; } }

  const FALLBACK_GRADIENTS = [
    'linear-gradient(135deg,#1a1a2e,#16213e)',
    'linear-gradient(135deg,#2d1b69,#11998e)',
    'linear-gradient(135deg,#8b0000,#1a0000)',
    'linear-gradient(135deg,#0f0c29,#302b63)',
    'linear-gradient(135deg,#1f1c2c,#928dab)',
  ];

  function renderCW() {
    const list = getCW().slice(0, 20);
    const section = document.getElementById('cw-rail-section')!;
    const rail = document.getElementById('cw-scroll')!;
    if (!section || !rail) return;
    if (list.length === 0) { section.style.display = 'none'; return; }
    section.style.display = 'block';

    rail.innerHTML = list.map((item: any, i: number) => {
      const href = `/watch/${item.slug || ''}?type=${item.type}&id=${item.id}`;
      const grad = FALLBACK_GRADIENTS[i % FALLBACK_GRADIENTS.length];
      const progress = item.progress || 0;
      const pct = Math.min(Math.max(progress, 0), 100);

      return `
        <a href="${href}" class="title-card" style="width:180px;flex-shrink:0;display:block;text-decoration:none;color:inherit" title="${item.title}">
          <div style="position:relative;aspect-ratio:2/3;overflow:hidden;border-radius:10px">
            ${item.poster
              ? `<img src="${item.poster}" alt="${item.title}" loading="lazy" width="180" height="270" style="width:100%;height:100%;object-fit:cover;display:block" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">`
              : ''}
            <div style="position:absolute;inset:0;background:${grad};display:${item.poster ? 'none' : 'flex'};align-items:center;justify-content:center;padding:8px">
              <span style="font-size:13px;font-weight:700;color:rgba(255,255,255,0.45);text-align:center;line-height:1.3;word-break:break-word">${item.title}</span>
            </div>
            <!-- Progress bar -->
            ${pct > 0 ? `<div style="position:absolute;bottom:0;left:0;right:0;height:3px;background:rgba(255,255,255,0.15)"><div style="height:100%;width:${pct}%;background:#e50914;border-radius:2px"></div></div>` : ''}
            <!-- Play overlay -->
            <div class="card-overlay">
              <div class="card-overlay-play">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
              </div>
              <p class="card-overlay-title">${item.title}</p>
              <p class="card-overlay-meta">${item.year || ''}</p>
            </div>
          </div>
          <div style="padding:6px 4px">
            <p style="font-size:13px;font-weight:600;color:#fff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin:0">${item.title}</p>
            <span style="font-size:11px;color:var(--color-muted)">${item.season ? `S${item.season} E${item.episode || 1}` : item.year || ''}</span>
          </div>
        </a>`;
    }).join('');
  }

  document.getElementById('cw-clear-btn')?.addEventListener('click', () => {
    try { localStorage.removeItem(CW_KEY); } catch {}
    const section = document.getElementById('cw-rail-section')!;
    if (section) section.style.display = 'none';
  });

  renderCW();
</script>
