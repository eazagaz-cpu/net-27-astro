---
import { getPosterUrl, fallbackPoster } from '../lib/media';

interface Props {
  title: string;
  slug: string;
  type: 'movie' | 'show' | 'anime';
  year: number;
  rating: number;
  poster: string;
  quality?: string;
  genres?: string[];
}

const { title, slug, type, year, rating, poster, quality, genres = [] } = Astro.props;
const href = type === 'movie' ? `/movies/${slug}/` : `/shows/${slug}/`;
const posterUrl = getPosterUrl(poster);
const fallback = fallbackPoster(title);
const displayGenres = genres.slice(0, 2);
---

<a href={href} class="title-card group block" aria-label={`${title} (${year})`}>
  <div class="relative aspect-[2/3] overflow-hidden">
    {posterUrl ? (
      <img
        src={posterUrl}
        alt={`${title} official poster`}
        class="w-full h-full object-cover"
        loading="lazy"
        decoding="async"
        width="342"
        height="513"
        onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
      />
    ) : null}
    <div
      class="w-full h-full items-center justify-center absolute inset-0"
      style={`background:${fallback};display:${posterUrl ? 'none' : 'flex'}`}
    >
      <span class="text-4xl font-bold text-white/20 select-none">{title.charAt(0)}</span>
    </div>

    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>

    {quality && (
      <span class="absolute top-2 right-2 px-1.5 py-0.5 rounded text-[9px] font-bold uppercase tracking-wider bg-[var(--color-primary)] text-white">{quality}</span>
    )}

    {rating > 0 && (
      <span class="absolute top-2 left-2 flex items-center gap-0.5 px-1.5 py-0.5 rounded bg-black/70 backdrop-blur-sm text-[11px] font-semibold text-white">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-2.5 h-2.5 text-yellow-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {rating.toFixed(1)}
      </span>
    )}
  </div>

  <div class="p-2.5">
    <h3 class="text-[13px] font-semibold text-white line-clamp-1 group-hover:text-[var(--color-primary)] transition-colors">{title}</h3>
    <div class="flex items-center gap-1.5 mt-1">
      <span class="text-[11px] text-[var(--color-muted)]">{year}</span>
      {type !== 'movie' && (
        <span class="text-[9px] px-1.5 py-0.5 rounded font-medium uppercase bg-[var(--color-accent)]/20 text-[var(--color-accent)]">
          {type === 'anime' ? 'ANIME' : 'TV'}
        </span>
      )}
    </div>
    {displayGenres.length > 0 && (
      <div class="flex gap-1 mt-1.5">
        {displayGenres.map(g => (
          <span class="text-[9px] px-1.5 py-0.5 rounded-full border border-white/10 text-[var(--color-muted)]">{g}</span>
        ))}
      </div>
    )}
  </div>
</a>
