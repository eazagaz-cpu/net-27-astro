---
/**
 * StaticRail.astro — Server-rendered (build-time) content carousel.
 * Uses pre-fetched TMDB cache from movie-sync.mjs.
 * Visually identical to DynamicRail.tsx but renders at build time (zero JS, SSR-friendly).
 * A small inline <script> handles scroll arrow clicks.
 */
import type { CachedItem } from '../lib/movie-cache';

interface Props {
  title: string;
  items: CachedItem[];
  viewAllHref?: string;
  /** Unique key used to scope scroll buttons. Defaults to slugified title. */
  railKey?: string;
  /** Badge shown next to the title (e.g. "NEW", "HOT") */
  badge?: string;
}

const { title, items, viewAllHref, badge } = Astro.props;

// Nothing to render if cache is empty (sync hasn't been run yet)
if (items.length === 0) return;

// Stable, URL-safe ID from the title
const railKey = Astro.props.railKey
  ?? title.replace(/[^a-z0-9]/gi, '-').toLowerCase().replace(/-+/g, '-').slice(0, 30);
const scrollId = `sr-${railKey}`;

const FALLBACK_GRADIENTS = [
  'linear-gradient(135deg,#1a1a2e,#16213e)',
  'linear-gradient(135deg,#2d1b69,#11998e)',
  'linear-gradient(135deg,#8b0000,#1a0000)',
  'linear-gradient(135deg,#0f0c29,#302b63)',
  'linear-gradient(135deg,#1f1c2c,#928dab)',
];
---

<section class="rail-section" style="padding:1rem 0">
  <div style="max-width:1400px;margin:0 auto;padding:0 1rem">

    <!-- Section header -->
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1rem">
      <div style="display:flex;align-items:center;gap:0.5rem">
        <h2 class="section-title">{title}</h2>
        {badge && (
          <span style="font-size:10px;font-weight:700;padding:2px 6px;border-radius:4px;background:var(--color-primary);color:#fff;text-transform:uppercase;letter-spacing:0.05em">
            {badge}
          </span>
        )}
      </div>
      {viewAllHref && (
        <a href={viewAllHref} style="font-size:12px;color:var(--color-primary);font-weight:500">View All →</a>
      )}
    </div>

    <!-- Rail with scroll arrows and fade edge -->
    <div class="static-rail-wrap rail-wrap" data-rail={scrollId}>

      <!-- Left arrow -->
      <button
        class="sr-arrow sr-arrow-left"
        data-target={scrollId}
        data-dir="left"
        aria-label="Scroll left"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
      </button>

      <!-- Scrollable items -->
      <div id={scrollId} class="scroll-rail">
        {items.map(item => {
          const href = `/detail/?type=${item.type}&id=${item.id}`;
          const grad = FALLBACK_GRADIENTS[item.id % FALLBACK_GRADIENTS.length];
          const hasPoster = !!item.posterUrl;
          return (
            <a
              href={href}
              class="title-card"
              style="width:180px;flex-shrink:0;display:block;text-decoration:none;color:inherit"
              title={item.title}
            >
              <div style="position:relative;aspect-ratio:2/3;overflow:hidden;border-radius:10px">

                {/* Poster image with client-side fallback */}
                {hasPoster && (
                  <img
                    src={item.posterUrl}
                    alt={`${item.title} poster`}
                    loading="lazy"
                    decoding="async"
                    width="180"
                    height="270"
                    style="width:100%;height:100%;object-fit:cover;display:block"
                    onerror="this.style.display='none';var fb=this.nextElementSibling;if(fb)fb.style.display='flex';"
                  />
                )}

                {/* Gradient fallback (hidden when poster loads) */}
                <div style={`position:absolute;inset:0;background:${grad};display:${hasPoster ? 'none' : 'flex'};align-items:center;justify-content:center;padding:8px`}>
                  <span style="font-size:13px;font-weight:700;color:rgba(255,255,255,0.45);text-align:center;line-height:1.3;word-break:break-word">
                    {item.title}
                  </span>
                </div>

                {/* SERIES badge — top left */}
                {item.type === 'tv' && (
                  <span style="position:absolute;top:6px;left:6px;font-size:9px;padding:2px 6px;border-radius:3px;font-weight:700;background:#e50914;color:#fff;text-transform:uppercase;letter-spacing:0.04em;z-index:4">
                    SERIES
                  </span>
                )}

                {/* Rating badge — top right */}
                {item.rating > 0 && (
                  <span style="position:absolute;top:6px;right:6px;display:flex;align-items:center;gap:2px;padding:2px 6px;border-radius:4px;background:rgba(0,0,0,0.75);backdrop-filter:blur(4px);font-size:11px;font-weight:600;color:#f5c518;z-index:4">
                    ★ {item.rating}
                  </span>
                )}

                {/* Hover overlay — Netflix style */}
                <div class="card-overlay">
                  <div class="card-overlay-play">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                  <p class="card-overlay-title">{item.title}</p>
                  <p class="card-overlay-meta">{item.year}{item.rating > 0 ? ` · ★ ${item.rating}` : ''}</p>
                </div>
              </div>

              <div style="padding:6px 4px">
                <p style="font-size:13px;font-weight:600;color:#fff;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;margin:0">
                  {item.title}
                </p>
                <span style="font-size:11px;color:var(--color-muted)">{item.year || ''}</span>
              </div>
            </a>
          );
        })}
      </div>

      <!-- Right arrow -->
      <button
        class="sr-arrow sr-arrow-right"
        data-target={scrollId}
        data-dir="right"
        aria-label="Scroll right"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<!-- Scroll arrow styles & behaviour (deduplicated by Astro across multiple instances) -->
<style is:global>
  .static-rail-wrap {
    position: relative;
  }
  .sr-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: rgba(0,0,0,0.8);
    backdrop-filter: blur(4px);
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
  }
  .static-rail-wrap:hover .sr-arrow {
    opacity: 1;
    pointer-events: auto;
  }
  .sr-arrow:hover {
    background: rgba(0,0,0,1);
  }
  .sr-arrow-left  { left:  0; }
  .sr-arrow-right { right: 0; }
</style>

<script>
  // Single delegated handler — runs once even when multiple StaticRail instances are on the page.
  const w = window as Window & { __srScrollInit?: boolean };
  if (!w.__srScrollInit) {
    w.__srScrollInit = true;
    document.addEventListener('click', (e) => {
      const btn = (e.target as Element).closest('[data-target][data-dir]') as HTMLElement | null;
      if (!btn) return;
      const rail = document.getElementById(btn.dataset.target!);
      if (!rail) return;
      rail.scrollBy({ left: btn.dataset.dir === 'left' ? -600 : 600, behavior: 'smooth' });
    });
  }
</script>
