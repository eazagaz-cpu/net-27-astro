---
import { getBackdropUrl } from '../lib/media';

interface HeroTitle {
  slug: string;
  type: 'movie' | 'show' | 'anime';
  title: string;
  year: number;
  rating: number;
  quality: string;
  ageRating?: string;
  overview: string;
  backdrop: string;
  genres?: string[];
}

interface Props {
  titles: HeroTitle[];
}

const { titles } = Astro.props;
const slides = titles.slice(0, 5);
---

<section class="relative w-full h-[62vh] md:h-[72vh] overflow-hidden" aria-label="Featured titles">
  {slides.map((slide, i) => {
    const bgUrl = getBackdropUrl(slide.backdrop, 'lg');
    const href = slide.type === 'movie' ? `/movies/${slide.slug}/` : `/shows/${slide.slug}/`;
    return (
      <div
        class:list={['hero-slide absolute inset-0 transition-opacity duration-700', i === 0 ? 'opacity-100' : 'opacity-0']}
        data-slide-index={i}
      >
        {bgUrl && (
          <img
            src={bgUrl}
            alt={`${slide.title} backdrop image`}
            class="absolute inset-0 w-full h-full object-cover object-top"
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding={i === 0 ? 'sync' : 'async'}
            fetchpriority={i === 0 ? 'high' : 'low'}
          />
        )}

        <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/50 to-transparent"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg)] via-transparent to-black/40"></div>

        <div class="relative z-10 h-full flex items-end pb-20 md:pb-24">
          <div class="max-w-[1400px] mx-auto px-4 w-full">
            <div class="max-w-xl">
              <div class="flex items-center gap-2 mb-3">
                <span class="text-[var(--color-primary)] text-xs font-bold uppercase tracking-widest">🔥 Trending Now</span>
              </div>

              <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black uppercase tracking-wide leading-tight mb-3" style="text-shadow: 0 2px 20px rgba(0,0,0,0.5);">
                {slide.title}
              </h2>

              <div class="flex items-center gap-3 mb-4 text-sm">
                <span class="flex items-center gap-1 bg-green-600/80 text-white px-2 py-0.5 rounded text-xs font-bold">
                  {slide.rating.toFixed(1)}
                </span>
                <span class="text-[var(--color-muted)]">{slide.year}</span>
                <span class="text-[var(--color-muted)]">&middot;</span>
                <span class="text-[var(--color-muted)] uppercase text-xs">{slide.type === 'movie' ? 'Movie' : slide.type === 'anime' ? 'Anime' : 'Series'}</span>
                {slide.quality && (
                  <>
                    <span class="text-[var(--color-muted)]">&middot;</span>
                    <span class="px-1.5 py-0.5 rounded text-[10px] font-bold bg-white/10 text-white">{slide.quality}</span>
                  </>
                )}
              </div>

              <p class="text-[var(--color-muted)] text-sm md:text-base leading-relaxed line-clamp-3 mb-6 max-w-lg">
                {slide.overview}
              </p>

              <div class="flex items-center gap-3">
                <a href={`/watch/${slide.slug}/`} class="btn-primary px-6 py-2.5 rounded-lg text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                  Watch Now
                </a>
                <a href={href} class="btn-glass px-6 py-2.5 rounded-lg text-sm">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  More Info
                </a>
              </div>
            </div>
          </div>
        </div>

        {slide.ageRating && (
          <div class="absolute bottom-20 right-4 md:right-8 z-10">
            <span class="px-2 py-1 border border-white/30 text-white/70 text-xs font-medium">{slide.ageRating}</span>
          </div>
        )}
      </div>
    );
  })}

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex items-center gap-2">
    {slides.map((_, i) => (
      <button
        class:list={['hero-dot w-2 h-2 rounded-full transition-all duration-300 cursor-pointer', i === 0 ? 'bg-white w-6' : 'bg-white/40']}
        data-dot-index={i}
        aria-label={`Go to slide ${i + 1}`}
      />
    ))}
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.hero-dot');
  let current = 0;
  let interval: ReturnType<typeof setInterval>;

  function goTo(idx: number) {
    slides.forEach((s, i) => {
      (s as HTMLElement).style.opacity = i === idx ? '1' : '0';
    });
    dots.forEach((d, i) => {
      d.classList.toggle('bg-white', i === idx);
      d.classList.toggle('w-6', i === idx);
      d.classList.toggle('bg-white/40', i !== idx);
      d.classList.toggle('w-2', i !== idx);
    });
    current = idx;
  }

  function next() {
    goTo((current + 1) % slides.length);
  }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      goTo(i);
      clearInterval(interval);
      interval = setInterval(next, 6000);
    });
  });

  interval = setInterval(next, 6000);

  const heroSection = slides[0]?.closest('section');
  heroSection?.addEventListener('mouseenter', () => clearInterval(interval));
  heroSection?.addEventListener('mouseleave', () => { interval = setInterval(next, 6000); });
</script>
