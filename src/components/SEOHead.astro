---
import { generateSEO } from '../lib/seo';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const seo = generateSEO(Astro.props);
const ogImageAlt = 'NetMirror - Movies, TV Shows, Anime and Hindi Dubbed Discovery';
---

<title>{seo.title}</title>
<meta name="description" content={seo.description} />
<link rel="canonical" href={seo.canonical} />

<!-- Open Graph -->
<meta property="og:title" content={seo.ogTitle} />
<meta property="og:description" content={seo.ogDescription} />
<meta property="og:image" content={seo.ogImage} />
<meta property="og:image:secure_url" content={seo.ogImage} />
<meta property="og:image:type" content="image/png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:url" content={seo.canonical} />
<meta property="og:type" content={seo.ogType} />
<meta property="og:site_name" content="NetMirror" />

<!-- Twitter Card -->
<meta name="twitter:card" content={seo.twitterCard} />
<meta name="twitter:title" content={seo.ogTitle} />
<meta name="twitter:description" content={seo.ogDescription} />
<meta name="twitter:image" content={seo.ogImage} />
<meta name="twitter:image:alt" content={ogImageAlt} />

{seo.noindex && <meta name="robots" content="noindex, nofollow" />}
