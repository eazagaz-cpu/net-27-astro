---

<footer class="bg-[var(--color-surface)] mt-12 border-t border-white/5">
  <div class="max-w-[1400px] mx-auto px-4 py-12">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-8">
      <!-- Brand -->
      <div class="col-span-2 sm:col-span-3 lg:col-span-1">
        <a href="/" class="inline-block mb-3">
          <span class="text-xl font-extrabold tracking-tight">
            <span class="text-[var(--color-primary)]">Net</span><span class="text-white">Mirror</span>
          </span>
        </a>
        <p class="text-[var(--color-muted)] text-xs leading-relaxed mb-3">
          Movies, shows & anime &middot; Multi-language audio &middot; 500k+ titles
        </p>
        <p class="text-[var(--color-text-muted)] text-[10px] leading-relaxed">
          {SITE_NAME} does not host or stream any content. We provide discovery and availability information only. All trademarks belong to their respective owners.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-white mb-3">Quick Links</h3>
        <ul class="space-y-1.5">
          {quickLinks.map(link => (
            <li><a href={link.href} class="text-xs text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Platforms -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-white mb-3">Platforms</h3>
        <ul class="space-y-1.5">
          {platforms.map(link => (
            <li><a href={link.href} class="text-xs text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Genres -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-white mb-3">Genres</h3>
        <ul class="space-y-1.5">
          {genres.map(link => (
            <li><a href={link.href} class="text-xs text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-white mb-3">Legal</h3>
        <ul class="space-y-1.5">
          {legalLinks.map(link => (
            <li><a href={link.href} class="text-xs text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Follow Us -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-white mb-3">Follow Us</h3>
        <div class="grid grid-cols-4 gap-2 max-w-[180px]">
          {socials.map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer nofollow"
              aria-label={s.label}
              class="social-icon-3d"
              style={`--icon-color: ${s.color}; --icon-glow: ${s.glow};`}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" set:html={s.icon} />
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom Bar: Copyright + Socials -->
  <div class="border-t border-white/5">
    <div class="max-w-[1400px] mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-[11px] text-[var(--color-text-muted)] text-center sm:text-left">
        &copy; {new Date().getFullYear()} {SITE_NAME}. All rights reserved. Contact: {CONTACT_EMAIL}
      </p>
      <div class="flex items-center gap-2">
        {socials.slice(0, 5).map(s => (
          <a href={s.href} target="_blank" rel="noopener noreferrer nofollow" aria-label={s.label} class="text-[var(--color-muted)] hover:text-white transition-colors" style={`color: var(--color-muted);`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" set:html={s.icon} />
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Languages Bar -->
  <div class="border-t border-white/5 bg-[var(--color-bg-primary)]">
    <div class="max-w-[1400px] mx-auto px-4 py-4">
      <LanguageSwitcher />
    </div>
  </div>
</footer>

<style>
  .social-icon-3d {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--icon-color);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .social-icon-3d:hover {
    transform: translateY(-4px) scale(1.08);
    box-shadow: 0 8px 25px var(--icon-glow), 0 2px 10px rgba(0, 0, 0, 0.3), inset 0 1px 0 rgba(255, 255, 255, 0.1);
    border-color: var(--icon-color);
    background: rgba(255, 255, 255, 0.1);
  }
</style>
