---
import { SITE_NAME, CONTACT_EMAIL } from '../lib/constants';

const quickLinks = [
  { label: 'Home', href: '/' },
  { label: 'Movies', href: '/movies/' },
  { label: 'TV Shows', href: '/shows/' },
  { label: 'Anime', href: '/anime/' },
  { label: 'Trending', href: '/trending/' },
  { label: 'Latest', href: '/latest/' },
  { label: 'Search', href: '/search/' },
];

const platforms = [
  { label: 'Netflix', href: '/platform/netflix/' },
  { label: 'Prime Video', href: '/platform/prime-video/' },
  { label: 'JioHotstar', href: '/platform/jiohotstar/' },
  { label: 'SonyLIV', href: '/platform/sonyliv/' },
  { label: 'Crunchyroll', href: '/platform/crunchyroll/' },
  { label: 'Disney+', href: '/platform/disney-plus/' },
];

const genres = [
  { label: 'Action', href: '/genre/action/' },
  { label: 'Comedy', href: '/genre/comedy/' },
  { label: 'Drama', href: '/genre/drama/' },
  { label: 'Sci-Fi', href: '/genre/sci-fi/' },
  { label: 'Thriller', href: '/genre/thriller/' },
  { label: 'Horror', href: '/genre/horror/' },
];

const legalLinks = [
  { label: 'About', href: '/about/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'Editorial Policy', href: '/editorial/' },
  { label: 'Privacy Policy', href: '/privacy/' },
  { label: 'Terms of Service', href: '/terms/' },
  { label: 'DMCA Policy', href: '/dmca/' },
  { label: 'Disclaimer', href: '/disclaimer/' },
];
---

<footer class="bg-[var(--color-surface)] mt-12 border-t border-white/5">
  <div class="max-w-[1400px] mx-auto px-4 py-12">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-8">
      <div class="col-span-2 sm:col-span-3 lg:col-span-1">
        <a href="/" class="inline-block mb-3">
          <span class="text-xl font-extrabold tracking-tight">
            <span class="text-[var(--color-primary)]">Net</span><span class="text-white">Mirror</span>
          </span>
        </a>
        <p class="text-[var(--color-muted)] text-xs leading-relaxed mb-3">
          Movies, shows & anime &middot; Multi-language audio &middot; 500k+ titles
        </p>
        <p class="text-[var(--color-text-muted)] text-[10px] leading-relaxed">
          {SITE_NAME} does not host or stream any content. We provide discovery and availability information only. All trademarks belong to their respective owners.
        </p>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-white mb-3">Quick Links</h3>
        <ul class="space-y-1.5">
          {quickLinks.map(link => (
            <li><a href={link.href} class="text-xs text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-white mb-3">Platforms</h3>
        <ul class="space-y-1.5">
          {platforms.map(link => (
            <li><a href={link.href} class="text-xs text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-white mb-3">Genres</h3>
        <ul class="space-y-1.5">
          {genres.map(link => (
            <li><a href={link.href} class="text-xs text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-white mb-3">Legal</h3>
        <ul class="space-y-1.5">
          {legalLinks.map(link => (
            <li><a href={link.href} class="text-xs text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <div class="border-t border-white/5">
    <div class="max-w-[1400px] mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-[11px] text-[var(--color-text-muted)]">
        &copy; {new Date().getFullYear()} {SITE_NAME}. All rights reserved. Contact: {CONTACT_EMAIL}
      </p>
      <div class="flex items-center gap-3">
        <a href={`mailto:${CONTACT_EMAIL}`} class="text-[var(--color-muted)] hover:text-[var(--color-primary)] transition-colors" aria-label="Email">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>
