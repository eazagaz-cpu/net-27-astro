---
import UserMenu from './auth/UserMenu.tsx';
const LANG_OPTIONS = [
  { code: 'en', native: 'English' },
  { code: 'hi', native: 'हिन्दी' },
  { code: 'ur', native: 'اردو' },
  { code: 'es', native: 'Español' },
  { code: 'ar', native: 'العربية' },
  { code: 'fr', native: 'Français' },
  { code: 'de', native: 'Deutsch' },
  { code: 'ru', native: 'Русский' },
  { code: 'ja', native: '日本語' },
  { code: 'ko', native: '한국어' },
  { code: 'pt', native: 'Português' },
  { code: 'tr', native: 'Türkçe' },
  { code: 'id', native: 'Indonesia' },
];

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Movies', href: '/movies/' },
  { label: 'TV Shows', href: '/shows/' },
  { label: 'Anime', href: '/anime/' },
  { label: 'Trending', href: '/trending/' },
  { label: 'Latest', href: '/latest/' },
  { label: 'Blog', href: '/blog/' },
];

const currentPath = Astro.url.pathname;

const platformChips: { label: string; href: string; iconHtml: string }[] = [
  { label: 'Trending', href: '/trending/', iconHtml: '<span style="font-size:14px">🔥</span>' },
  { label: 'Latest Release', href: '/latest/', iconHtml: '<span style="font-size:14px">✨</span>' },
  { label: 'Netflix', href: '/platform/netflix/', iconHtml: '<svg width="16" height="16" viewBox="0 0 24 24"><path fill="#E50914" d="M5.398 0v.006c3.028 8.556 5.37 15.175 8.348 23.596 2.344.058 4.85.398 4.854.398-2.8-7.924-5.923-16.747-8.487-24zm8.489 0v9.63L18.6 22.951l.049.031V0zm-13.887.02V24H4.79l-.004-11.087L9.383 24c.004 0 1.588-.048 4.382-.1v-.02L5.227.02z"/></svg>' },
  { label: 'Prime Video', href: '/platform/prime-video/', iconHtml: '<svg width="18" height="18" viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="3" fill="#00264D"/><polygon points="9.5,8 16,12 9.5,16" fill="#00A8E1"/><path d="M4 18.5c2.5-1.5 5.5-2.2 8-2.2s5.5.7 8 2.2" fill="none" stroke="#00A8E1" stroke-width="1.3" stroke-linecap="round"/></svg>' },
  { label: 'JioHotstar', href: '/platform/jiohotstar/', iconHtml: '<svg width="16" height="16" viewBox="0 0 24 24"><path fill="#1F80E0" d="M12 2l2.47 5.01L20 8.27l-4 3.89.94 5.51L12 14.77l-4.94 2.9.94-5.51-4-3.89 5.53-.76z"/><circle cx="12" cy="12" r="2" fill="#FFD700"/></svg>' },
  { label: 'SonyLIV', href: '/platform/sonyliv/', iconHtml: '<svg width="16" height="16" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="4" fill="#141414" stroke="#888" stroke-width="1"/><text x="12" y="16.5" text-anchor="middle" font-size="11" font-weight="800" fill="#fff" font-family="sans-serif">S</text></svg>' },
  { label: 'Crunchyroll', href: '/platform/crunchyroll/', iconHtml: '<svg width="16" height="16" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="#F47521"/><circle cx="14" cy="10" r="4" fill="#fff"/><circle cx="15" cy="9.5" r="2" fill="#F47521"/></svg>' },
  { label: 'Kids', href: '/genre/kids/', iconHtml: '<span style="font-size:14px">👶</span>' },
  { label: 'MX Player', href: '/platform/mx-player/', iconHtml: '<svg width="16" height="16" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" fill="#0B7BDB"/><polygon points="9,6 18,12 9,18" fill="#fff"/></svg>' },
];
---

<header class="fixed top-0 left-0 right-0 z-50">
  <div class="bg-gradient-to-b from-black/90 via-black/70 to-transparent backdrop-blur-sm">
    <div class="max-w-[1400px] mx-auto px-4 h-16 flex items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-1 shrink-0">
        <span class="text-xl font-extrabold tracking-tight">
          <span class="text-[var(--color-primary)]">Net</span><span class="text-white">Mirror</span>
        </span>
      </a>

      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class:list={[
              'px-3 py-1.5 rounded-lg text-sm font-medium transition-colors',
              currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))
                ? 'text-[var(--color-primary)]'
                : 'text-[var(--color-muted)] hover:text-white',
            ]}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        <button id="header-search-btn" class="hidden md:flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-sm text-[var(--color-muted)] hover:border-white/20 hover:text-white transition-colors w-56 lg:w-72 cursor-pointer" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <span>Search movies, shows, anime...</span>
        </button>
        <button id="header-search-btn-mobile" class="md:hidden p-2 text-[var(--color-muted)] hover:text-white transition-colors" aria-label="Search">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        </button>
        <!-- Watchlist -->
        <a href="/watchlist/" aria-label="My Watchlist" title="My Watchlist" class="hidden md:flex items-center justify-center w-9 h-9 rounded-full bg-white/5 border border-white/10 text-[var(--color-muted)] hover:border-white/20 hover:text-white transition-colors" id="header-wl-btn">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
        </a>
        <!-- Language Picker -->
        <div class="lang-picker-wrap" id="lang-picker-wrap">
          <button id="lang-picker-btn" class="lang-picker-btn" aria-label="Select language" title="Change language">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
            <span id="lang-current-label">EN</span>
          </button>
          <div id="lang-dropdown" class="lang-dropdown" role="listbox" aria-label="Language options">
            <button class="lang-option" data-lang="en" role="option">English</button>
            <button class="lang-option" data-lang="hi" role="option">हिन्दी</button>
            <button class="lang-option" data-lang="ur" role="option">اردو</button>
            <button class="lang-option" data-lang="es" role="option">Español</button>
            <button class="lang-option" data-lang="ar" role="option">العربية</button>
            <button class="lang-option" data-lang="fr" role="option">Français</button>
            <button class="lang-option" data-lang="de" role="option">Deutsch</button>
            <button class="lang-option" data-lang="ru" role="option">Русский</button>
            <button class="lang-option" data-lang="ja" role="option">日本語</button>
            <button class="lang-option" data-lang="ko" role="option">한국어</button>
            <button class="lang-option" data-lang="pt" role="option">Português</button>
            <button class="lang-option" data-lang="tr" role="option">Türkçe</button>
            <button class="lang-option" data-lang="id" role="option">Indonesia</button>
          </div>
        </div>
        <UserMenu client:idle />
        <button id="mobile-menu-toggle" class="lg:hidden p-2 text-[var(--color-muted)] hover:text-white transition-colors" aria-label="Toggle menu" aria-expanded="false">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>

    <div class="max-w-[1400px] mx-auto px-4 pb-2 hidden md:block">
      <div class="flex items-center gap-2 overflow-x-auto pb-1" style="scrollbar-width:none;">
        {platformChips.map(chip => (
          <a
            href={chip.href}
            class:list={[
              'flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-medium border transition-all shrink-0',
              currentPath === chip.href
                ? 'bg-[var(--color-primary)] border-[var(--color-primary)] text-white'
                : 'bg-white/5 border-white/10 text-[var(--color-muted)] hover:border-white/20 hover:text-white',
            ]}
          >
            <span class="chip-icon" set:html={chip.iconHtml} />
            {chip.label}
          </a>
        ))}
      </div>
    </div>

    <!-- Announcement ticker -->
    <div class="announcement-bar">
      <div class="announcement-track" id="announcement-track">
        <p class="announcement-item">If a movie isn't playing on one server, switch to another server instantly from the player controls</p>
        <p class="announcement-item">NetMirror supports 4 streaming servers — if one is slow or shows ads, try the next for a cleaner experience</p>
        <p class="announcement-item">Download the NetMirror APK for Android — faster browsing, smoother playback, and offline access</p>
        <p class="announcement-item">Use the Report button on the player to flag bad servers — we'll prioritize better ones for you</p>
        <p class="announcement-item">500,000+ movies and TV shows across Netflix, Prime Video, JioHotstar, Crunchyroll and 30+ platforms</p>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="fixed inset-0 bg-black/95 backdrop-blur-xl z-50 hidden lg:hidden" aria-hidden="true">
    <div class="flex flex-col h-full">
      <div class="flex items-center justify-between px-4 h-16">
        <a href="/" class="text-xl font-extrabold tracking-tight">
          <span class="text-[var(--color-primary)]">Net</span><span class="text-white">Mirror</span>
        </a>
        <button id="mobile-menu-close" class="p-2 text-[var(--color-muted)] hover:text-white" aria-label="Close menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <nav class="flex flex-col px-4 py-6 gap-1" aria-label="Mobile navigation">
        {navLinks.map(link => (
          <a href={link.href} class="px-4 py-3 rounded-xl text-lg font-medium text-[var(--color-muted)] hover:text-white hover:bg-white/5 transition-all">{link.label}</a>
        ))}
        <a href="/watchlist/" class="px-4 py-3 rounded-xl text-lg font-medium text-[var(--color-muted)] hover:text-white hover:bg-white/5 transition-all flex items-center gap-2">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>
          My Watchlist
        </a>
      </nav>
      <div class="px-4 py-4">
        <p class="text-xs text-[var(--color-text-muted)] mb-3">Platforms</p>
        <div class="flex flex-wrap gap-2">
          {platformChips.map(chip => (
            <a href={chip.href} class="chip text-xs flex items-center gap-1.5"><span set:html={chip.iconHtml} /> {chip.label}</a>
          ))}
        </div>
      </div>
      <div class="px-4 mt-auto pb-8">
        <a href="/search/" class="btn-primary w-full justify-center py-3 rounded-xl">Search</a>
      </div>
    </div>
  </div>
</header>

<style>
  .lang-picker-wrap {
    position: relative;
  }
  .lang-picker-btn {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 6px 10px;
    border-radius: 8px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.7);
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .lang-picker-btn:hover {
    background: rgba(255,255,255,0.12);
    border-color: rgba(255,255,255,0.25);
    color: #fff;
  }
  .lang-dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 160px;
    background: #1a1a2e;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px;
    padding: 6px;
    z-index: 200;
    box-shadow: 0 16px 48px rgba(0,0,0,0.6);
    max-height: 320px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.1) transparent;
  }
  .lang-dropdown.open {
    display: block;
    animation: dropIn 0.15s ease;
  }
  @keyframes dropIn {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .lang-option {
    display: block;
    width: 100%;
    padding: 8px 12px;
    border-radius: 8px;
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.75);
    font-size: 13px;
    font-weight: 500;
    text-align: left;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }
  .lang-option:hover {
    background: rgba(255,255,255,0.08);
    color: #fff;
  }
  .lang-option.active {
    background: rgba(229,9,20,0.15);
    color: #e50914;
    font-weight: 700;
  }
</style>

<script is:inline>
(function() {
  var KEY = 'netmirror_lang';
  var saved = localStorage.getItem(KEY) || 'en';

  // Show current lang in button
  var lbl = document.getElementById('lang-current-label');
  if (lbl) lbl.textContent = saved.toUpperCase();

  // Mark active option
  var opts = document.querySelectorAll('.lang-option');
  for (var i = 0; i < opts.length; i++) {
    if (opts[i].getAttribute('data-lang') === saved) opts[i].classList.add('active');
  }

  var btn = document.getElementById('lang-picker-btn');
  var dd = document.getElementById('lang-dropdown');
  var wrap = document.getElementById('lang-picker-wrap');
  if (!btn || !dd || !wrap) return;

  btn.addEventListener('click', function(e) {
    e.stopPropagation();
    dd.classList.toggle('open');
  });

  document.addEventListener('click', function(e) {
    if (!wrap.contains(e.target)) dd.classList.remove('open');
  });

  dd.addEventListener('click', function(e) {
    var opt = e.target;
    while (opt && !opt.classList.contains('lang-option')) opt = opt.parentElement;
    if (!opt) return;
    var code = opt.getAttribute('data-lang');
    if (!code || code === saved) { dd.classList.remove('open'); return; }
    localStorage.setItem(KEY, code);
    window.location.reload();
  });
})();
</script>

<script is:inline>
(function(){
  function openSearch(){
    document.dispatchEvent(new CustomEvent('nm:search:open'));
  }
  var btn = document.getElementById('header-search-btn');
  var btnM = document.getElementById('header-search-btn-mobile');
  if(btn) btn.addEventListener('click', openSearch);
  if(btnM) btnM.addEventListener('click', openSearch);
  // Keyboard shortcut: press / to open search
  document.addEventListener('keydown', function(e){
    if(e.key==='/' && e.target.tagName!=='INPUT' && e.target.tagName!=='TEXTAREA'){
      e.preventDefault(); openSearch();
    }
  });
})();
</script>

<script>
  let menuScrollY = 0;
  const toggle = document.getElementById('mobile-menu-toggle');
  const close = document.getElementById('mobile-menu-close');
  const menu = document.getElementById('mobile-menu');

  function openMenu() {
    if (!menu) return;
    menuScrollY = window.scrollY;
    menu.classList.remove('hidden');
    menu.setAttribute('aria-hidden', 'false');
    document.body.style.position = 'fixed';
    document.body.style.top = `-${menuScrollY}px`;
    document.body.style.left = '0';
    document.body.style.right = '0';
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    if (!menu) return;
    menu.classList.add('hidden');
    menu.setAttribute('aria-hidden', 'true');
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.left = '';
    document.body.style.right = '';
    document.body.style.overflow = '';
    window.scrollTo({ top: menuScrollY, behavior: 'instant' as ScrollBehavior });
  }

  if (toggle && close && menu) {
    toggle.addEventListener('click', openMenu);
    close.addEventListener('click', closeMenu);
    menu.querySelectorAll('a').forEach(l => l.addEventListener('click', closeMenu));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu.classList.contains('hidden')) closeMenu();
    });
  }
</script>
