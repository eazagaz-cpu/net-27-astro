---
import { APK_UNIVERSAL_URL, APK_ARM64_URL, APK_ARM32_URL, TELEGRAM_URL, CONTACT_EMAIL } from '../lib/constants';
---

<section class="relative z-10 -mt-4">
  <div class="max-w-3xl mx-auto px-4">
    <div class="glass-card rounded-2xl px-6 py-4 flex flex-col sm:flex-row items-center justify-center gap-3">
      <a
        href={APK_UNIVERSAL_URL}
        download
        rel="noopener noreferrer"
        data-event="download_app_universal"
        class="flex items-center gap-2 text-sm text-[var(--color-muted)] hover:text-white transition-colors"
        aria-label="Download NetMirror app"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
        Get the app
      </a>

      <div class="flex items-center gap-2">
        <a
          href={APK_UNIVERSAL_URL}
          download
          rel="noopener noreferrer"
          data-event="download_app_universal"
          class="btn-primary text-xs px-4 py-2 rounded-lg"
          aria-label="Download app for Phone"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          Phone
        </a>

        <a
          href="#"
          data-event="download_tv_app"
          class="btn-glass text-xs px-4 py-2 rounded-lg"
          aria-label="Download app for TV"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          TV
        </a>

        <a
          href={TELEGRAM_URL}
          target="_blank"
          rel="noopener noreferrer"
          data-event="open_telegram"
          class="btn-glass text-xs px-4 py-2 rounded-lg"
          aria-label="Join Telegram channel"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          Telegram
        </a>
      </div>
    </div>

    <div class="flex items-center justify-center gap-2 mt-2 text-xs text-[var(--color-text-muted)]">
      <span>Older device or "App not installed"? Try</span>
      <a
        href={APK_ARM64_URL}
        download
        rel="noopener noreferrer"
        data-event="download_app_arm64"
        class="text-[var(--color-accent)] hover:underline"
      >arm64 (45 MB)</a>
      <span>&middot;</span>
      <a
        href={APK_ARM32_URL}
        download
        rel="noopener noreferrer"
        data-event="download_app_arm32"
        class="text-[var(--color-accent)] hover:underline"
      >arm32 (42 MB)</a>
    </div>
  </div>
</section>
