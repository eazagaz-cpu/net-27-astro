---
interface Props {
  pros: string[];
  cons: string[];
  title?: string;
}
const { pros, cons, title } = Astro.props;
---

<div class="blog-proscons my-8 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-card)] overflow-hidden">
  {title && <p class="px-5 pt-4 text-xs font-bold uppercase tracking-wider text-[var(--color-text-muted)]">{title}</p>}
  <div class="grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-[var(--color-border)]">
    <div class="p-5">
      <p class="text-sm font-bold text-green-400 mb-3 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
        Pros
      </p>
      <ul class="space-y-2">
        {pros.map(p => (
          <li class="flex items-start gap-2 text-sm text-[var(--color-text-secondary)]">
            <span class="text-green-400 mt-0.5 shrink-0">+</span>
            <span>{p}</span>
          </li>
        ))}
      </ul>
    </div>
    <div class="p-5">
      <p class="text-sm font-bold text-red-400 mb-3 flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
        Cons
      </p>
      <ul class="space-y-2">
        {cons.map(c => (
          <li class="flex items-start gap-2 text-sm text-[var(--color-text-secondary)]">
            <span class="text-red-400 mt-0.5 shrink-0">-</span>
            <span>{c}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>
