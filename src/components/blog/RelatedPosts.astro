---
interface RelatedPost {
  slug: string;
  title: string;
  excerpt: string;
  image: string;
  readTime: string;
  tags: string[];
}

interface Props {
  posts: RelatedPost[];
}
const { posts } = Astro.props;
---

{posts.length > 0 && (
  <div class="blog-related my-10">
    <h2 class="text-xl font-bold mb-6 text-[var(--color-text-primary)]">Related Articles</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {posts.map(post => (
        <a href={`/blog/${post.slug}/`} class="glass-card group rounded-xl overflow-hidden hover:border-[var(--color-primary)]/40 transition-all duration-300">
          <div class="aspect-[16/9] overflow-hidden">
            <img
              src={post.image}
              alt={post.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
              loading="lazy"
              decoding="async"
              width="400"
              height="225"
            />
          </div>
          <div class="p-4">
            <h3 class="text-sm font-bold mb-1.5 line-clamp-2 group-hover:text-[var(--color-primary)] transition-colors">{post.title}</h3>
            <p class="text-xs text-[var(--color-text-muted)]">{post.readTime}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
)}
