---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';
import Schema from '../../components/Schema.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import DynamicGrid from '../../components/DynamicGrid.tsx';
import { breadcrumbSchema } from '../../lib/schema';
import { SITE_URL } from '../../lib/seo';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Trending', href: '/trending/' },
];
---

<BaseLayout>
  <SEOHead slot="head" title="Trending — Popular Movies & Shows This Week" description="See what everyone is watching this week. Trending movies, TV shows and anime across Netflix, Prime Video, Disney+ and more." canonical={`${SITE_URL}/trending/`} />
  <Schema slot="head" schema={breadcrumbSchema(breadcrumbs)} />
  <Header />
  <main class="min-h-screen pt-36">
    <div class="max-w-[1400px] mx-auto px-4 py-8">
      <Breadcrumbs items={breadcrumbs} />
      <h1 class="text-3xl md:text-4xl font-bold mb-2">🔥 Trending Now</h1>
      <p class="text-[var(--color-muted)] mb-8">Movies and shows everyone is watching this week across all platforms.</p>
      <DynamicGrid client:idle category="trending" title="Trending" />
    </div>
  </main>
  <Footer />
</BaseLayout>
