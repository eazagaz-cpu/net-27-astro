---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';
import Schema from '../../components/Schema.astro';
import TitleCard from '../../components/TitleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { actors, getActorTitles, directors } from '../../data/entities';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';
import { SITE_URL } from '../../lib/seo';

export const getStaticPaths = (() => {
  return actors.map(actor => ({
    params: { slug: actor.slug },
    props: { actor },
  }));
}) satisfies GetStaticPaths;

const { actor } = Astro.props;
const titles = getActorTitles(actor);

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Actors', href: '/' },
  { label: actor.name, href: `/actor/${actor.slug}/` },
];

// Find related directors from the actor's titles
const relatedDirectorNames = [...new Set(titles.map(t => t.director))];
const relatedDirectors = directors.filter(d => relatedDirectorNames.includes(d.name));

// Collect unique genres from the actor's titles
const actorGenres = [...new Set(titles.flatMap(t => t.genres))];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: actor.name,
  description: actor.bio,
  birthDate: String(actor.birthYear),
  nationality: actor.nationality,
  jobTitle: 'Actor',
  url: `${SITE_URL}/actor/${actor.slug}/`,
};

const faqs = [
  { question: `What movies and shows has ${actor.name} appeared in?`, answer: `${actor.name} has appeared in ${titles.length} titles in our database, including ${titles.slice(0, 3).map(t => t.title).join(', ')}. Browse the full filmography below.` },
  { question: `What genre is ${actor.name} known for?`, answer: `${actor.name} is best known for ${actor.knownFor.join(', ')} roles. Their filmography spans a range of genres that showcase their versatile acting abilities.` },
  { question: `Where is ${actor.name} from?`, answer: `${actor.name} is ${actor.nationality}. They were born in ${actor.birthYear} and have built an international career across film and television.` },
  { question: `Where can I watch ${actor.name}'s movies and shows?`, answer: `${actor.name}'s titles are available on various streaming platforms including Netflix, Prime Video, Disney+, and more. Check each title page for specific availability.` },
  { question: `Is ${actor.name} in any trending titles?`, answer: `Check the filmography section below to see all of ${actor.name}'s titles, including any that are currently trending on major streaming platforms.` },
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={`${actor.name} - Movies & Shows`}
    description={`Explore ${actor.name}'s filmography including ${titles.length} movies and shows. ${actor.bio.split('.')[0]}.`}
    canonical={`${SITE_URL}/actor/${actor.slug}/`}
  />
  <Schema slot="head" schema={[breadcrumbSchema(breadcrumbs), faqSchema(faqs), personSchema]} />

  <Header />

  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-primary)]/10 to-[var(--color-accent)]/10"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-primary)] to-transparent"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-8">
        <Breadcrumbs items={breadcrumbs} />

        <div class="mt-4 mb-2">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight">
            <span class="gradient-text">{actor.name}</span> - Movies & Shows
          </h1>
          <div class="mt-4 flex flex-wrap gap-3">
            <span class="chip">{actor.nationality}</span>
            <span class="chip">Born {actor.birthYear}</span>
            {actor.knownFor.map(genre => (
              <span class="chip">{genre}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 space-y-16">

      <!-- Bio Section -->
      <section class="glass-card rounded-xl p-8">
        <h2 class="section-title mb-4">Biography</h2>
        <p class="text-[var(--color-text-secondary)] text-lg leading-relaxed">{actor.bio}</p>
      </section>

      <!-- Filmography -->
      <section>
        <h2 class="section-title mb-6">Filmography ({titles.length} titles)</h2>
        {titles.length > 0 ? (
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
            {titles.map(title => (
              <TitleCard title={title} />
            ))}
          </div>
        ) : (
          <div class="glass-card rounded-xl p-12 text-center">
            <p class="text-[var(--color-text-muted)] text-lg">No titles found for this actor.</p>
          </div>
        )}
      </section>

      <!-- FAQs -->
      <section>
        <h2 class="section-title mb-6">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {faqs.map(faq => (
            <details class="glass-card rounded-xl p-6 group">
              <summary class="cursor-pointer text-white font-semibold text-lg flex items-center justify-between">
                {faq.question}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-text-muted)] group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-4 text-[var(--color-text-secondary)] leading-relaxed">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- Related Directors -->
      {relatedDirectors.length > 0 && (
        <section>
          <h2 class="section-title mb-6">Directors Who Worked With {actor.name}</h2>
          <div class="flex flex-wrap gap-3">
            {relatedDirectors.map(d => (
              <a href={`/director/${d.slug}/`} class="chip">
                {d.name}
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Related Genres -->
      {actorGenres.length > 0 && (
        <section>
          <h2 class="section-title mb-6">Explore Genres</h2>
          <div class="flex flex-wrap gap-3">
            {actorGenres.map(g => (
              <a href={`/genre/${g.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}/`} class="chip">
                {g}
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Legal Disclaimer -->
      <section class="glass-card rounded-xl p-6">
        <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
          <strong class="text-[var(--color-text-secondary)]">Disclaimer:</strong> Net27 does not host, store, or distribute any copyrighted content. All information provided on this page is for informational purposes only. We help users discover titles and find legal streaming options. All trademarks, service marks, and content referenced belong to their respective owners.
        </p>
      </section>

    </div>
  </main>

  <Footer />
</BaseLayout>
