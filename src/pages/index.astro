---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import Schema from '../components/Schema.astro';
import HeroSlider from '../components/HeroSlider.astro';
import DynamicHero from '../components/DynamicHero.tsx';
import AppCTA from '../components/AppCTA.astro';
import DynamicRail from '../components/DynamicRail.tsx';
import StaticRail from '../components/StaticRail.astro';
import ContinueWatching from '../components/ContinueWatching.astro';
import Top10Rail from '../components/Top10Rail.tsx';
import SearchBlock from '../components/SearchBlock.astro';
import FAQSection from '../components/FAQSection.astro';
import { websiteSchema, organizationSchema, softwareAppSchema } from '../lib/schema';
import { SITE_URL } from '../lib/seo';
import { SITE_NAME } from '../lib/constants';
import { getAllRealTitles } from '../lib/realTitles';
import { getCachedItems } from '../lib/movie-cache';
import { getAllBlogPosts } from '../data/blogPosts';

const featured = [...getAllRealTitles()]
  .sort((a, b) => b.rating - a.rating)
  .slice(0, 5)
  .map(t => ({
    slug: t.slug,
    tmdbId: t.tmdbId,
    type: t.type,
    title: t.title,
    year: t.year,
    rating: t.rating,
    overview: t.overview,
    backdrop: t.backdropUrl,
    genres: t.genres,
  }));

// Build-time pre-fetched data (from movie-sync.mjs cache).
// Returns [] gracefully if sync hasn't been run yet.
const cachedTrending      = getCachedItems('trending',         20);
const cachedLatest        = getCachedItems('latest-movies',    20);
const cachedNetflix       = getCachedItems('netflix',          20);
const cached2026          = getCachedItems('new-2026',         20);
const cachedHindiDubbed   = getCachedItems('hindi-dubbed',     20);
const cachedUpcoming      = getCachedItems('upcoming',         20);
const cachedTrakt         = getCachedItems('trakt-trending',   20);
const cachedPakistani     = getCachedItems('pakistani-drama',  20);
const cachedTurkish       = getCachedItems('turkish-drama',    20);
const latestPosts         = getAllBlogPosts().slice(0, 3);

const homeFaqs = [
  { question: 'What is NetMirror?', answer: 'NetMirror is a movie and show discovery platform that helps you find where to watch movies, TV shows, and anime across streaming services like Netflix, Prime Video, JioHotstar, SonyLIV, Crunchyroll, and more. We provide availability information — we do not host or stream any content.' },
  { question: 'How to search movies on NetMirror?', answer: 'Use the search bar at the top of any page or visit the /search/ page. You can search by movie title, show name, actor, director, genre, or platform. Results appear instantly from our database of 500k+ titles.' },
  { question: 'How to download the NetMirror app?', answer: 'Click the "Get the app" or "Phone" button in the app download section on our homepage. The app is available as an APK for Android devices. Choose the Universal version for most devices, or ARM64/ARM32 for specific architectures.' },
  { question: 'Which APK version should I choose?', answer: 'For most modern Android devices, choose the Universal APK. If you know your device architecture: use ARM64 for newer 64-bit devices, or ARM32 for older 32-bit devices. The Universal version works on all architectures.' },
  { question: 'Is NetMirror free to use?', answer: 'Yes, NetMirror is completely free. We help you discover where to watch content legally across streaming platforms. The website and app are free with no subscriptions required.' },
  { question: 'Does NetMirror stream movies?', answer: 'No. NetMirror is a discovery platform only. We provide information about where movies and shows are available on official streaming services. We do not host, upload, or stream any copyrighted content.' },
  { question: 'How to contact NetMirror?', answer: 'You can reach us at net27.cc@gmail.com for support, feedback, DMCA notices, or business inquiries. Visit our contact page for more options.' },
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="NetMirror - Watch Movies, TV Shows, Anime & Hindi Dubbed Titles Online"
    description="Explore NetMirror for trending movies, TV shows, anime, Hindi dubbed titles, Bollywood releases, platform-based discovery, and Android app download guidance."
    canonical={`${SITE_URL}/`}
  />
  <Schema slot="head" schema={[websiteSchema(), organizationSchema(), softwareAppSchema()]} />

  <Header />

  <main>
    <!-- Hero: server-rendered with cached data — visible immediately, no blank flash -->
    <DynamicHero client:load initialItems={cachedTrending} />
    <noscript><HeroSlider titles={featured} /></noscript>

    <!-- App Download CTA -->
    <AppCTA />

    <!-- Genre browsing pills -->
    <div style="max-width:1400px;margin:0 auto;padding:1.25rem 1rem 0">
      <div class="genre-pills-row">
        <a href="/genre/action/" class="genre-pill">⚡ Action</a>
        <a href="/genre/drama/" class="genre-pill">🎭 Drama</a>
        <a href="/genre/comedy/" class="genre-pill">😄 Comedy</a>
        <a href="/genre/thriller/" class="genre-pill">🔪 Thriller</a>
        <a href="/genre/romance/" class="genre-pill">💕 Romance</a>
        <a href="/genre/horror/" class="genre-pill">👻 Horror</a>
        <a href="/anime/" class="genre-pill">⛩️ Anime</a>
        <a href="/genre/sci-fi/" class="genre-pill">🚀 Sci-Fi</a>
        <a href="/genre/documentary/" class="genre-pill">🎬 Docs</a>
        <a href="/genre/kids/" class="genre-pill">🧒 Kids</a>
        <a href="/language/hindi/" class="genre-pill">🇮🇳 Hindi</a>
        <a href="/language/korean/" class="genre-pill">🇰🇷 Korean</a>
        <a href="/language/turkish/" class="genre-pill">🇹🇷 Turkish</a>
      </div>
    </div>

    <!-- Surprise Me button -->
    <div style="max-width:1400px;margin:0 auto;padding:0.5rem 1rem 0;display:flex;justify-content:flex-end">
      <button
        id="surprise-me-btn"
        style="display:flex;align-items:center;gap:8px;padding:8px 18px;border-radius:999px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:#fff;font-size:13px;font-weight:600;cursor:pointer;transition:all 0.2s"
        onmouseenter="this.style.background='rgba(229,9,20,0.2)';this.style.borderColor='#e50914'"
        onmouseleave="this.style.background='rgba(255,255,255,0.08)';this.style.borderColor='rgba(255,255,255,0.15)'"
      >
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.929 4.929a10 10 0 1114.142 0M12 8v4l3 3"/></svg>
        Surprise Me
      </button>
    </div>
    <script>
      (function() {
        var btn = document.getElementById('surprise-me-btn');
        if (!btn) return;
        btn.addEventListener('click', function() {
          var rails = document.querySelectorAll('.title-card[href]');
          var all = Array.from(rails).filter(function(el) { return (el as HTMLAnchorElement).href; });
          if (all.length === 0) return;
          var pick = all[Math.floor(Math.random() * all.length)] as HTMLAnchorElement;
          window.location.href = pick.href;
        });
      })();
    </script>

    <!-- Continue Watching — client-side localStorage rail -->
    <ContinueWatching />

    <!-- Top 10 — directly after hero, no CTA interruption -->
    <Top10Rail client:visible mediaType="movie" />
    <Top10Rail client:visible mediaType="tv" />

    <!-- Core sections — same structure as competitor -->
    <StaticRail title="Trending Now"            items={cachedTrending}   viewAllHref="/trending/"  railKey="trending" />
    <StaticRail title="Latest Releases (2025–2026)" items={cachedLatest} viewAllHref="/latest/"    railKey="latest-movies" />
    <StaticRail title="Popular on Netflix"           items={cachedNetflix}       viewAllHref="/platform/netflix/" railKey="netflix" />
    <StaticRail title="New in 2026"                  items={cached2026}          viewAllHref="/latest/"           railKey="new-2026" />
    <StaticRail title="Hindi Dubbed Hits"            items={cachedHindiDubbed}  viewAllHref="/genre/action/"     railKey="hindi-dubbed" />
    {cachedPakistani.length > 0 && <StaticRail title="Pakistani Dramas"  items={cachedPakistani} railKey="pakistani-drama" badge="PK" />}
    {cachedTurkish.length  > 0 && <StaticRail title="Turkish Dramas (Urdu Dubbed)" items={cachedTurkish}  railKey="turkish-drama"   badge="TR" />}
    {cachedTrakt.length > 0 && <StaticRail title="Trending on Trakt" items={cachedTrakt} railKey="trakt-trending" />}
    <DynamicRail client:visible title="Action Movies"      category="action"   viewAllHref="/genre/action/" />
    <DynamicRail client:visible title="Drama Series"       category="drama"    viewAllHref="/genre/drama/" />
    <DynamicRail client:visible title="Comedy"             category="comedy"   viewAllHref="/genre/comedy/" />
    <DynamicRail client:visible title="Thrillers"          category="thriller" viewAllHref="/genre/thriller/" />
    <DynamicRail client:visible title="Romance"            category="romance"  viewAllHref="/genre/romance/" />
    <DynamicRail client:visible title="Horror"             category="horror"   viewAllHref="/genre/horror/" />
    <DynamicRail client:visible title="Animation & Family" category="kids"     viewAllHref="/genre/kids/" />
    <StaticRail title="Trending Globally — Coming Soon" items={cachedUpcoming} railKey="upcoming" badge="Upcoming" />

    <!-- Search Block -->
    <SearchBlock />

    <!-- SEO Content Block -->
    <section class="py-10">
      <div class="max-w-[1400px] mx-auto px-4">
        <div class="glass-card rounded-2xl p-6 md:p-8">
          <h2 class="text-lg font-bold mb-3">{SITE_NAME} — Your Movie & Show Discovery Platform</h2>
          <div class="text-sm text-[var(--color-muted)] space-y-3 leading-relaxed">
            <p>
              {SITE_NAME} is your comprehensive guide to discovering movies, TV shows, and anime across all major streaming platforms. Whether you're looking for the latest blockbuster on Netflix, a critically acclaimed series on Prime Video, regional content on JioHotstar or SonyLIV, or the newest anime on Crunchyroll — {SITE_NAME} helps you find it all in one place.
            </p>
            <p>
              Our platform provides detailed information about every title including cast, director, ratings, genres, available languages, streaming platform availability, and personalized recommendations. With over 500,000 titles in our database, {SITE_NAME} is the most comprehensive movie discovery tool available. We support content in multiple languages including English, Hindi, Tamil, Telugu, Korean, Japanese, Spanish, and many more.
            </p>
            <p>
              {SITE_NAME} respects intellectual property rights and does not host, upload, store, or stream any copyrighted content. We are a discovery and information platform that directs users to official, legally licensed streaming services. All trademarks, logos, and content referenced belong to their respective owners.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Latest from the Blog -->
    {latestPosts.length > 0 && (
      <section class="py-10">
        <div class="max-w-[1400px] mx-auto px-4">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold">Latest from the Blog</h2>
            <a href="/blog/" class="text-sm text-[var(--color-primary)] hover:underline">View all articles →</a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {latestPosts.map(post => (
              <a href={`/blog/${post.slug}/`} class="glass-card rounded-xl p-5 hover:border-[var(--color-primary)]/40 transition-all group">
                <span class="text-xs font-medium text-[var(--color-primary)] uppercase tracking-wider">{post.category}</span>
                <h3 class="mt-2 text-base font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-primary)] transition-colors line-clamp-2">{post.title}</h3>
                <p class="mt-2 text-sm text-[var(--color-text-muted)] line-clamp-2">{post.excerpt}</p>
                <div class="mt-3 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
                  <span>{post.readTime}</span>
                  <span>&middot;</span>
                  <time>{post.date}</time>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- FAQ Section -->
    <section class="py-6">
      <div class="max-w-[1400px] mx-auto px-4">
        <FAQSection faqs={homeFaqs} title="Frequently Asked Questions" />
      </div>
    </section>

    <!-- Disclaimer -->
    <section class="py-6 border-t border-white/5">
      <div class="max-w-[1400px] mx-auto px-4">
        <p class="text-[10px] text-[var(--color-text-muted)] text-center leading-relaxed">
          Disclaimer: {SITE_NAME} does not host, store, or distribute any media content. We are a discovery platform that helps users find where to watch movies, TV shows, and anime legally through official streaming services. All content information, images, and trademarks belong to their respective owners. Download only from official {SITE_NAME} links. For support, contact net27.cc@gmail.com.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
