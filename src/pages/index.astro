---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import Schema from '../components/Schema.astro';
import HeroSlider from '../components/HeroSlider.astro';
import AppCTA from '../components/AppCTA.astro';
import ContentRail from '../components/ContentRail.astro';
import SearchBlock from '../components/SearchBlock.astro';
import FAQSection from '../components/FAQSection.astro';
import { websiteSchema, organizationSchema, softwareAppSchema, faqSchema } from '../lib/schema';
import { SITE_URL, SITE_DESCRIPTION } from '../lib/seo';
import { SITE_NAME } from '../lib/constants';
import { getTrending, getLatest, getFeatured, getTop10, getByType, getByPlatform } from '../data/titles';

const featured = getFeatured();
const trending = getTrending();
const latest = getLatest();
const top10 = getTop10();
const movies = getByType('movie').slice(0, 12);
const shows = getByType('show').slice(0, 12);
const anime = getByType('anime').slice(0, 12);
const netflixPicks = getByPlatform('Netflix').slice(0, 12);
const primePicks = getByPlatform('Prime Video').slice(0, 12);
const crunchyrollPicks = getByPlatform('Crunchyroll').slice(0, 12);

const homeFaqs = [
  { question: 'What is NetMirror?', answer: 'NetMirror is a movie and show discovery platform that helps you find where to watch movies, TV shows, and anime across streaming services like Netflix, Prime Video, JioHotstar, SonyLIV, Crunchyroll, and more. We provide availability information — we do not host or stream any content.' },
  { question: 'How to search movies on NetMirror?', answer: 'Use the search bar at the top of any page or visit the /search/ page. You can search by movie title, show name, actor, director, genre, or platform. Results appear instantly from our database of 500k+ titles.' },
  { question: 'How to download the NetMirror app?', answer: 'Click the "Get the app" or "Phone" button in the app download section on our homepage. The app is available as an APK for Android devices. Choose the Universal version for most devices, or ARM64/ARM32 for specific architectures.' },
  { question: 'Which APK version should I choose?', answer: 'For most modern Android devices, choose the Universal APK. If you know your device architecture: use ARM64 for newer 64-bit devices, or ARM32 for older 32-bit devices. The Universal version works on all architectures.' },
  { question: 'Is NetMirror free to use?', answer: 'Yes, NetMirror is completely free. We help you discover where to watch content legally across streaming platforms. The website and app are free with no subscriptions required.' },
  { question: 'Does NetMirror stream movies?', answer: 'No. NetMirror is a discovery platform only. We provide information about where movies and shows are available on official streaming services. We do not host, upload, or stream any copyrighted content.' },
  { question: 'How to contact NetMirror?', answer: 'You can reach us at net27.cc@gmail.com for support, feedback, DMCA notices, or business inquiries. Visit our contact page for more options.' },
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="Movies, Shows & Anime - Watch Online"
    description={SITE_DESCRIPTION}
    canonical={`${SITE_URL}/`}
  />
  <Schema slot="head" schema={[websiteSchema(), organizationSchema(), softwareAppSchema(), faqSchema(homeFaqs)]} />

  <Header />

  <main>
    <!-- Hero Slider -->
    <HeroSlider titles={featured.length > 0 ? featured : trending.slice(0, 5)} />

    <!-- App Download CTA -->
    <AppCTA />

    <!-- Popular Movies -->
    <ContentRail title="Popular Movies" titles={movies} viewAllHref="/movies/" />

    <!-- Top 10 Today -->
    <ContentRail title="Top 10 Today" titles={top10} />

    <!-- Trending Now -->
    <ContentRail title="Trending Now" titles={trending} viewAllHref="/trending/" />

    <!-- Latest Releases -->
    <ContentRail title="Latest Releases" titles={latest} viewAllHref="/latest/" />

    <!-- Netflix Picks -->
    {netflixPicks.length > 0 && (
      <ContentRail title="Netflix" titles={netflixPicks} viewAllHref="/platform/netflix/" />
    )}

    <!-- Prime Video Picks -->
    {primePicks.length > 0 && (
      <ContentRail title="Prime Video" titles={primePicks} viewAllHref="/platform/prime-video/" />
    )}

    <!-- Crunchyroll Anime -->
    {crunchyrollPicks.length > 0 && (
      <ContentRail title="Crunchyroll" titles={crunchyrollPicks} viewAllHref="/platform/crunchyroll/" />
    )}

    <!-- Anime Section -->
    <ContentRail title="Anime" titles={anime} viewAllHref="/anime/" />

    <!-- TV Shows -->
    <ContentRail title="TV Shows" titles={shows} viewAllHref="/shows/" />

    <!-- Search Block -->
    <SearchBlock />

    <!-- SEO Content Block -->
    <section class="py-10">
      <div class="max-w-[1400px] mx-auto px-4">
        <div class="glass-card rounded-2xl p-6 md:p-8">
          <h2 class="text-lg font-bold mb-3">{SITE_NAME} — Your Movie & Show Discovery Platform</h2>
          <div class="text-sm text-[var(--color-muted)] space-y-3 leading-relaxed">
            <p>
              {SITE_NAME} is your comprehensive guide to discovering movies, TV shows, and anime across all major streaming platforms. Whether you're looking for the latest blockbuster on Netflix, a critically acclaimed series on Prime Video, regional content on JioHotstar or SonyLIV, or the newest anime on Crunchyroll — {SITE_NAME} helps you find it all in one place.
            </p>
            <p>
              Our platform provides detailed information about every title including cast, director, ratings, genres, available languages, streaming platform availability, and personalized recommendations. With over 500,000 titles in our database, {SITE_NAME} is the most comprehensive movie discovery tool available. We support content in multiple languages including English, Hindi, Tamil, Telugu, Korean, Japanese, Spanish, and many more.
            </p>
            <p>
              {SITE_NAME} respects intellectual property rights and does not host, upload, store, or stream any copyrighted content. We are a discovery and information platform that directs users to official, legally licensed streaming services. All trademarks, logos, and content referenced belong to their respective owners.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-6">
      <div class="max-w-[1400px] mx-auto px-4">
        <FAQSection faqs={homeFaqs} title="Frequently Asked Questions" />
      </div>
    </section>

    <!-- Disclaimer -->
    <section class="py-6 border-t border-white/5">
      <div class="max-w-[1400px] mx-auto px-4">
        <p class="text-[10px] text-[var(--color-text-muted)] text-center leading-relaxed">
          Disclaimer: {SITE_NAME} does not host, store, or distribute any media content. We are a discovery platform that helps users find where to watch movies, TV shows, and anime legally through official streaming services. All content information, images, and trademarks belong to their respective owners. Download only from official {SITE_NAME} links. For support, contact net27.cc@gmail.com.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
