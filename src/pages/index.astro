---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import Schema from '../components/Schema.astro';
import HeroSlider from '../components/HeroSlider.astro';
import TitleCard from '../components/TitleCard.astro';
import { getTrendingTitles, getLatestTitles, genres, languages, platforms } from '../data/sampleTitles';
import { websiteSchema, organizationSchema } from '../lib/schema';
import { SITE_URL } from '../lib/seo';

const trending = getTrendingTitles();
const latest = getLatestTitles();
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="Discover Movies, TV Shows & Anime"
    description="Your ultimate destination for discovering movies, TV shows, and anime. Find where to watch legally across Netflix, Prime Video, Disney+, and more streaming platforms."
    canonical={`${SITE_URL}/`}
  />
  <Schema slot="head" schema={[websiteSchema(), organizationSchema()]} />

  <Header />

  <main class="min-h-screen">
    <!-- Hero Slider -->
    <HeroSlider titles={trending} />

    <!-- Trending Now Section -->
    <section class="py-12 md:py-16">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex items-center justify-between mb-8">
          <h2 class="section-title">Trending Now</h2>
          <a href="/trending/" class="text-sm text-[var(--color-primary)] hover:text-[var(--color-primary)]/80 transition-colors font-medium">
            View All &rarr;
          </a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 md:gap-6">
          {trending.map(title => <TitleCard title={title} />)}
        </div>
      </div>
    </section>

    <!-- Latest Releases Section -->
    <section class="py-12 md:py-16 bg-[var(--color-bg-secondary)]">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex items-center justify-between mb-8">
          <h2 class="section-title">Latest Releases</h2>
          <a href="/latest/" class="text-sm text-[var(--color-primary)] hover:text-[var(--color-primary)]/80 transition-colors font-medium">
            View All &rarr;
          </a>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 md:gap-6">
          {latest.map(title => <TitleCard title={title} />)}
        </div>
      </div>
    </section>

    <!-- Browse by Genre Section -->
    <section class="py-12 md:py-16">
      <div class="max-w-7xl mx-auto px-4">
        <h2 class="section-title mb-8">Browse by Genre</h2>
        <div class="flex flex-wrap gap-3">
          {genres.map(genre => (
            <a
              href={`/genre/${genre.slug}/`}
              class="chip group"
            >
              <span class="group-hover:text-[var(--color-primary)] transition-colors">{genre.name}</span>
              <span class="text-[var(--color-text-muted)] text-xs">({genre.count})</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Browse by Language Section -->
    <section class="py-12 md:py-16 bg-[var(--color-bg-secondary)]">
      <div class="max-w-7xl mx-auto px-4">
        <h2 class="section-title mb-8">Browse by Language</h2>
        <div class="flex flex-wrap gap-3">
          {languages.map(lang => (
            <a
              href={`/language/${lang.slug}/`}
              class="chip group"
            >
              <span class="group-hover:text-[var(--color-primary)] transition-colors">{lang.name}</span>
              <span class="text-[var(--color-text-muted)] text-xs">({lang.count})</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Browse by Platform Section -->
    <section class="py-12 md:py-16">
      <div class="max-w-7xl mx-auto px-4">
        <h2 class="section-title mb-8">Browse by Platform</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
          {platforms.map(platform => (
            <a
              href={`/platform/${platform.slug}/`}
              class="glass-card p-6 text-center hover:border-[var(--color-primary)]/50 transition-all duration-300 group"
            >
              <h3 class="text-lg font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-primary)] transition-colors mb-1">
                {platform.name}
              </h3>
              <p class="text-sm text-[var(--color-text-muted)]">{platform.count} titles</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Search CTA Section -->
    <section class="py-16 md:py-24 bg-gradient-to-br from-[var(--color-bg-primary)] via-[var(--color-bg-secondary)] to-[var(--color-bg-primary)]">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h2 class="text-3xl md:text-4xl lg:text-5xl font-extrabold mb-4 gradient-text">
          Find Your Next Favorite
        </h2>
        <p class="text-lg text-[var(--color-text-secondary)] max-w-2xl mx-auto mb-8">
          Search across thousands of movies, TV shows, and anime. Discover hidden gems and find out where to stream them legally.
        </p>
        <a href="/search/" class="btn-primary inline-flex items-center gap-2 text-lg px-8 py-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          Start Searching
        </a>
      </div>
    </section>

    <!-- App Promo Section (Placeholder) -->
    <section class="py-12 md:py-16">
      <div class="max-w-7xl mx-auto px-4">
        <div class="glass-card p-8 md:p-12 text-center">
          <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold uppercase tracking-wider bg-[var(--color-accent)]/20 text-[var(--color-accent)] mb-4">
            Coming Soon
          </span>
          <h2 class="text-2xl md:text-3xl font-bold mb-4 text-[var(--color-text-primary)]">
            Net27 Mobile App
          </h2>
          <p class="text-[var(--color-text-secondary)] max-w-xl mx-auto mb-6">
            Track your watchlist, get personalized recommendations, and never miss a new release. Our mobile app is currently in development and will be available soon on iOS and Android.
          </p>
          <div class="flex items-center justify-center gap-4">
            <span class="btn-secondary opacity-60 cursor-not-allowed inline-flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
              iOS - Coming Soon
            </span>
            <span class="btn-secondary opacity-60 cursor-not-allowed inline-flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
              Android - Coming Soon
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- Disclaimer -->
    <section class="py-8 border-t border-[var(--color-border)]">
      <div class="max-w-7xl mx-auto px-4">
        <p class="text-xs text-[var(--color-text-muted)] text-center leading-relaxed">
          Disclaimer: Net27 does not host, store, or distribute any media content. We are a discovery platform that helps users find where to watch movies, TV shows, and anime legally through official streaming services. All content information, images, and trademarks belong to their respective owners.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
