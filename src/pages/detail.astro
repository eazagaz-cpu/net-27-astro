---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import { SITE_URL } from '../lib/seo';
import { APK_UNIVERSAL_URL } from '../lib/constants';
---

<BaseLayout>
  <SEOHead slot="head" title="Title Details" description="Discover movie and show details on NetMirror." canonical={`${SITE_URL}/detail/`} />
  <Header />
  <main class="min-h-screen pt-16" id="detail-root">
    <div class="flex items-center justify-center min-h-[60vh]">
      <div class="text-center">
        <div class="w-10 h-10 border-2 border-white/20 border-t-[var(--color-primary)] rounded-full animate-spin mx-auto mb-4"></div>
        <p class="text-[var(--color-muted)] text-sm">Loading details...</p>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ APK_UNIVERSAL_URL }}>
  const params = new URLSearchParams(window.location.search);
  const type = params.get('type') || 'movie';
  const id = params.get('id') || '';
  const root = document.getElementById('detail-root');

  if (!id || !root) {
    if (root) root.innerHTML = '<div class="flex items-center justify-center min-h-[60vh] text-center"><div><h2 class="text-2xl font-bold mb-2">No Title Selected</h2><a href="/" class="btn-primary mt-4 inline-flex">Go Home</a></div></div>';
  } else {
    fetch(`/api/tmdb/details?type=${type}&id=${id}`)
      .then(r => r.json())
      .then(data => {
        if (data.error && !data.title) {
          root.innerHTML = '<div class="flex items-center justify-center min-h-[60vh] text-center"><div><h2 class="text-2xl font-bold mb-2">Title Not Found</h2><p class="text-zinc-400">Could not load this title.</p><a href="/" class="btn-primary mt-4 inline-flex">Go Home</a></div></div>';
          return;
        }
        document.title = `${data.title} (${data.year}) | NetMirror`;

        const trailerBtn = data.trailerKey ? `<a href="https://www.youtube.com/watch?v=${data.trailerKey}" target="_blank" rel="noopener noreferrer nofollow" class="btn-glass px-5 py-2.5 rounded-lg text-sm">▶ Trailer</a>` : '';
        const castHtml = (data.cast || []).slice(0, 10).map(c =>
          `<div class="flex flex-col items-center gap-1 w-20 shrink-0">
            ${c.profileUrl ? `<img src="${c.profileUrl}" alt="${c.name}" class="w-14 h-14 rounded-full object-cover" loading="lazy"/>` : `<div class="w-14 h-14 rounded-full bg-white/10 flex items-center justify-center text-lg font-bold text-white/40">${c.name.charAt(0)}</div>`}
            <span class="text-[11px] text-center text-white truncate w-full">${c.name}</span>
            <span class="text-[9px] text-zinc-500 text-center truncate w-full">${c.character || ''}</span>
          </div>`
        ).join('');
        const recsHtml = (data.recommendations || []).filter(r => r.posterUrl).slice(0, 8).map(r =>
          `<a href="/detail/?type=${r.type}&id=${r.id}" class="title-card block" style="width:140px;flex-shrink:0">
            <div class="aspect-[2/3] rounded-lg overflow-hidden"><img src="${r.posterUrl}" alt="${r.title}" class="w-full h-full object-cover" loading="lazy"/></div>
            <p class="text-xs font-medium mt-1 truncate text-white">${r.title}</p>
            <span class="text-[10px] text-zinc-500">${r.year || ''}</span>
          </a>`
        ).join('');

        root.innerHTML = `
          <div class="relative min-h-[50vh] md:min-h-[60vh]">
            ${data.backdropUrl ? `<img src="${data.backdropUrl}" alt="" class="absolute inset-0 w-full h-full object-cover"/>` : ''}
            <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/60 to-transparent"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg)] via-transparent to-black/40"></div>
            <div class="relative z-10 max-w-[1400px] mx-auto px-4 flex items-end pb-12 pt-24 gap-8 min-h-[50vh] md:min-h-[60vh]">
              ${data.posterUrl ? `<div class="hidden md:block w-56 shrink-0"><img src="${data.posterUrl}" alt="${data.title}" class="w-full rounded-xl shadow-2xl"/></div>` : ''}
              <div class="flex-1 max-w-2xl">
                ${data.tagline ? `<p class="text-[var(--color-primary)] text-xs font-bold uppercase tracking-wider mb-2">${data.tagline}</p>` : ''}
                <h1 class="text-3xl md:text-5xl font-black mb-3">${data.title}</h1>
                <div class="flex items-center gap-3 mb-4 text-sm flex-wrap">
                  <span class="bg-green-600/80 text-white px-2 py-0.5 rounded text-xs font-bold">${data.rating}</span>
                  <span class="text-zinc-400">${data.year}</span>
                  ${data.runtime ? `<span class="text-zinc-400">${data.runtime}</span>` : ''}
                  <span class="text-zinc-400 uppercase text-xs">${data.type === 'tv' ? 'TV Series' : 'Movie'}</span>
                  ${data.seasons ? `<span class="text-zinc-400">${data.seasons} Seasons</span>` : ''}
                </div>
                <div class="flex flex-wrap gap-2 mb-4">${(data.genres || []).map(g => `<span class="chip text-xs">${g}</span>`).join('')}</div>
                <p class="text-zinc-400 text-sm leading-relaxed mb-6 line-clamp-4">${data.overview}</p>
                <div class="flex items-center gap-3 flex-wrap">
                  <a href="/player/?type=${type}&id=${id}" class="btn-primary px-6 py-2.5 rounded-lg text-sm">▶ Watch Now</a>
                  ${trailerBtn}
                  <a href="${APK_UNIVERSAL_URL}" download class="btn-glass px-5 py-2.5 rounded-lg text-sm" rel="noopener noreferrer">⬇ App</a>
                </div>
              </div>
            </div>
          </div>
          <div class="max-w-[1400px] mx-auto px-4 py-10 space-y-10">
            <div id="enrichment-section"></div>
            ${castHtml ? `<section><h2 class="section-title mb-4">Cast</h2><div class="scroll-rail gap-4">${castHtml}</div></section>` : ''}
            ${recsHtml ? `<section><h2 class="section-title mb-4">More Like This</h2><div class="scroll-rail gap-3">${recsHtml}</div></section>` : ''}
            <section class="glass-card rounded-xl p-5 text-xs text-zinc-500">NetMirror does not host or stream content. Discovery and availability information only.</section>
          </div>`;

        // Fetch enrichment data (OMDb ratings, Watchmode availability, YouTube trailer, TVmaze episodes)
        fetch(`/api/media/enrich?title=${encodeURIComponent(data.title)}&year=${data.year}&type=${type}`)
          .then(r => r.json())
          .then(enrich => {
            const section = document.getElementById('enrichment-section');
            if (!section) return;
            let html = '';

            // Ratings from OMDb
            if (enrich.ratings && (enrich.ratings.imdb || enrich.ratings.rottenTomatoes || enrich.ratings.metacritic)) {
              html += '<section><h2 class="section-title mb-4">Ratings</h2><div class="flex flex-wrap gap-4">';
              if (enrich.ratings.imdb) html += `<div class="glass-card rounded-xl px-5 py-3 text-center"><p class="text-xs text-zinc-400 mb-1">IMDb</p><p class="text-lg font-bold text-yellow-400">⭐ ${enrich.ratings.imdb}</p></div>`;
              if (enrich.ratings.rottenTomatoes) html += `<div class="glass-card rounded-xl px-5 py-3 text-center"><p class="text-xs text-zinc-400 mb-1">Rotten Tomatoes</p><p class="text-lg font-bold text-red-400">🍅 ${enrich.ratings.rottenTomatoes}</p></div>`;
              if (enrich.ratings.metacritic) html += `<div class="glass-card rounded-xl px-5 py-3 text-center"><p class="text-xs text-zinc-400 mb-1">Metacritic</p><p class="text-lg font-bold text-green-400">🟢 ${enrich.ratings.metacritic}</p></div>`;
              html += '</div>';
              if (enrich.awards) html += `<p class="text-sm text-zinc-400 mt-3">🏆 ${enrich.awards}</p>`;
              html += '</section>';
            }

            // Availability from Watchmode
            if (enrich.availability && enrich.availability.length > 0) {
              const unique = [...new Map(enrich.availability.map(a => [a.name, a])).values()];
              html += '<section><h2 class="section-title mb-4">Where to Watch</h2><div class="flex flex-wrap gap-3">';
              for (const src of unique) {
                html += `<a href="${src.webUrl}" target="_blank" rel="noopener noreferrer nofollow" class="glass-card rounded-xl px-4 py-3 flex items-center gap-2 hover:border-[var(--color-primary)]/50 transition-all text-sm"><span class="text-white font-medium">${src.name}</span><span class="text-[10px] text-zinc-500 uppercase">${src.type}</span></a>`;
              }
              html += '</div></section>';
            }

            // YouTube trailer
            if (enrich.trailer && enrich.trailer.embedUrl) {
              html += `<section><h2 class="section-title mb-4">Official Trailer</h2><div class="aspect-video rounded-xl overflow-hidden max-w-3xl"><iframe src="${enrich.trailer.embedUrl}" class="w-full h-full" allowfullscreen allow="autoplay; encrypted-media" loading="lazy"></iframe></div></section>`;
            }

            // TVmaze episode guide
            let epGuide = null;
            if (enrich.episodeGuide && enrich.episodeGuide.totalSeasons > 0) {
              html += `<style>.ep-season-btn{padding:4px 12px;border-radius:20px;font-size:12px;font-weight:600;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);color:#a1a1aa;cursor:pointer;transition:all .15s}.ep-season-btn:hover{background:rgba(255,255,255,0.1);color:#fff}.ep-season-active{background:var(--color-primary)!important;border-color:var(--color-primary)!important;color:#fff!important}</style>`;
              epGuide = enrich.episodeGuide;
              const seasonNums = Object.keys(epGuide.seasons).map(Number).sort((a, b) => a - b);
              const latest = seasonNums[seasonNums.length - 1];
              const latestEps = epGuide.seasons[latest] || [];

              function epRow(ep) {
                return `<div class="glass-card rounded-xl px-4 py-3 flex items-start gap-3">
                  <div class="text-xs text-zinc-500 font-mono shrink-0 pt-0.5 w-12">S${String(ep.s).padStart(2,'0')}E${String(ep.e).padStart(2,'0')}</div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-white truncate">${ep.name}</p>
                    ${ep.summary ? `<p class="text-xs text-zinc-500 mt-0.5 line-clamp-2">${ep.summary}</p>` : ''}
                  </div>
                  <div class="text-xs text-zinc-600 shrink-0 pt-0.5">${ep.airdate}</div>
                </div>`;
              }

              html += `<section>
                <h2 class="section-title mb-4">Episode Guide <span class="text-sm text-zinc-500 font-normal">${epGuide.totalSeasons} seasons · ${epGuide.totalEpisodes} episodes</span></h2>
                <div class="flex items-center gap-2 mb-4 flex-wrap" id="ep-season-tabs">
                  ${seasonNums.map(s => `<button class="ep-season-btn${s === latest ? ' ep-season-active' : ''}" data-season="${s}">S${s}</button>`).join('')}
                </div>
                <div id="ep-list" class="grid gap-1.5">${latestEps.map(epRow).join('')}</div>
              </section>`;
            }

            if (html) {
              section.innerHTML = html;

              // Attach season tab listeners after DOM is set
              if (epGuide) {
                const guide = epGuide;
                function epRow2(ep) {
                  return `<div class="glass-card rounded-xl px-4 py-3 flex items-start gap-3">
                    <div class="text-xs text-zinc-500 font-mono shrink-0 pt-0.5 w-12">S${String(ep.s).padStart(2,'0')}E${String(ep.e).padStart(2,'0')}</div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-white truncate">${ep.name}</p>
                      ${ep.summary ? `<p class="text-xs text-zinc-500 mt-0.5 line-clamp-2">${ep.summary}</p>` : ''}
                    </div>
                    <div class="text-xs text-zinc-600 shrink-0 pt-0.5">${ep.airdate}</div>
                  </div>`;
                }
                document.querySelectorAll('.ep-season-btn').forEach(btn => {
                  btn.addEventListener('click', () => {
                    document.querySelectorAll('.ep-season-btn').forEach(b => b.classList.remove('ep-season-active'));
                    btn.classList.add('ep-season-active');
                    const s = parseInt(btn.dataset.season || '1');
                    const eps = guide.seasons[s] || [];
                    const list = document.getElementById('ep-list');
                    if (list) list.innerHTML = eps.map(epRow2).join('');
                  });
                });
              }
            }
          })
          .catch(() => {});
      })
      .catch(() => {
        root.innerHTML = '<div class="flex items-center justify-center min-h-[60vh] text-center"><div><h2 class="text-2xl font-bold mb-2">Error</h2><p class="text-zinc-400 mb-4">Could not load title.</p><a href="/" class="btn-primary inline-flex">Go Home</a></div></div>';
      });
  }
</script>
