---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
import Schema from '../components/Schema.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { breadcrumbSchema, organizationSchema } from '../lib/schema';
import { SITE_URL } from '../lib/seo';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about/' },
];

const features = [
  {
    title: 'Smart Discovery',
    description: 'Find exactly what you want to watch with our intelligent search and filtering system. Browse by genre, language, platform, and more.',
    icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z',
  },
  {
    title: 'Legal Streaming',
    description: 'We only show legitimate streaming options. Know exactly where each title is available before you subscribe to a new platform.',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  },
  {
    title: 'Comprehensive Database',
    description: 'Movies, TV shows, and anime all in one place. Our database covers titles from every major streaming platform worldwide.',
    icon: 'M7 4V2a1 1 0 011-1h8a1 1 0 011 1v2m-2 4h.01M12 12h.01M8 12h.01M12 16h.01M8 16h.01M16 12h.01M16 16h.01M7 20h10a2 2 0 002-2V8a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z',
  },
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="About Net27"
    description="Learn about Net27 - your ultimate movie, TV show, and anime discovery platform. Find where to watch legally across all streaming platforms."
    canonical={`${SITE_URL}/about/`}
  />
  <Schema slot="head" schema={[breadcrumbSchema(breadcrumbs), organizationSchema()]} />

  <Header />

  <main class="min-h-screen pt-20">
    <section class="relative py-16 md:py-24 bg-gradient-to-br from-[var(--color-bg-primary)] via-[var(--color-bg-secondary)] to-[var(--color-bg-primary)]">
      <div class="max-w-7xl mx-auto px-4">
        <Breadcrumbs items={breadcrumbs} />
        <div class="max-w-3xl">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
            About <span class="gradient-text">Net27</span>
          </h1>
          <p class="text-xl text-[var(--color-text-secondary)] leading-relaxed">
            We believe finding great content to watch should be effortless. Net27 is your companion for discovering movies, TV shows, and anime across every major streaming platform.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4">
        <div class="max-w-3xl space-y-6 text-[var(--color-text-secondary)] text-lg leading-relaxed">
          <p>
            Net27 was built out of a simple frustration: with dozens of streaming platforms available today, finding where to watch a specific title shouldn't require checking each service individually. We created a unified discovery platform that aggregates availability information so you can spend less time searching and more time watching.
          </p>
          <p>
            Our platform covers movies, TV shows, and anime from all major streaming services including Netflix, Prime Video, Disney+, Hulu, Apple TV+, Crunchyroll, HBO Max, and Paramount+. Whether you're looking for the latest blockbuster, a classic drama, or the newest anime series, Net27 helps you find it instantly.
          </p>
          <p>
            We are committed to supporting legal streaming. Net27 does not host, stream, or distribute any copyrighted content. We provide discovery and availability information only, directing users to official streaming platforms where titles can be watched legally.
          </p>
        </div>
      </div>
    </section>

    <section class="py-16 bg-[var(--color-bg-secondary)]">
      <div class="max-w-7xl mx-auto px-4">
        <h2 class="section-title mb-12 text-center justify-center">What We Offer</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {features.map(feature => (
            <div class="glass-card rounded-xl p-8 text-center">
              <div class="w-14 h-14 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center mx-auto mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-[var(--color-primary)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
                </svg>
              </div>
              <h3 class="text-xl font-bold mb-3">{feature.title}</h3>
              <p class="text-[var(--color-text-secondary)]">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 text-center">
        <h2 class="section-title mb-6 justify-center">Have Questions?</h2>
        <p class="text-[var(--color-text-secondary)] mb-8 max-w-xl mx-auto">
          We'd love to hear from you. Whether you have feedback, suggestions, or just want to say hello, feel free to reach out.
        </p>
        <a href="/contact/" class="btn-primary">Contact Us</a>
      </div>
    </section>

    <section class="py-8 border-t border-[var(--color-border)]">
      <div class="max-w-7xl mx-auto px-4">
        <p class="text-xs text-[var(--color-text-muted)] text-center">
          Net27 does not host, store, or stream any copyrighted content. All information is for discovery purposes only. All trademarks and content belong to their respective owners.
        </p>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
