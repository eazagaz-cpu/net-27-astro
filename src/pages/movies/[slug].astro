---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';
import Schema from '../../components/Schema.astro';
import TitleCard from '../../components/TitleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQSection from '../../components/FAQSection.astro';
import { getRealTitlesByType, getRelatedRealTitles } from '../../lib/realTitles';
import { genres } from '../../data/sampleTitles';
import { breadcrumbSchema, movieSchema, faqSchema, watchActionSchema } from '../../lib/schema';
import { SITE_URL } from '../../lib/seo';
import { APK_UNIVERSAL_URL } from '../../lib/constants';

export const getStaticPaths = (() => {
  return getRealTitlesByType('movie').map(title => ({
    params: { slug: title.slug },
    props: { title },
  }));
}) satisfies GetStaticPaths;

const { title } = Astro.props;
const related = getRelatedRealTitles(title);
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Movies', href: '/movies/' },
  { label: title.title, href: `/movies/${title.slug}/` },
];

const titleGenres = genres.filter(g => title.genres.includes(g.name));

const faqs = [
  { question: `Where can I watch ${title.title}?`, answer: `Check the "Available Now" section on this page for official streaming platforms carrying ${title.title} in your region.` },
  { question: `What is ${title.title} about?`, answer: title.overview },
  ...(title.cast.length > 0 ? [{ question: `Who stars in ${title.title}?`, answer: `The cast of ${title.title} includes ${title.cast.slice(0, 5).map(c => c.role ? `${c.name} as ${c.role}` : c.name).join(', ')}.` }] : []),
  ...(title.director ? [{ question: `Who directed ${title.title}?`, answer: `${title.title} was directed by ${title.director}.` }] : []),
  { question: `What is the rating of ${title.title}?`, answer: `${title.title} has a rating of ${title.rating}/10 on TMDB, released on ${title.releaseDate || title.year}.` },
  { question: `What genre is ${title.title}?`, answer: `${title.title} is categorized as ${title.genres.join(', ') || 'a feature film'}, released in ${title.year}.` },
];

const placeholderGradients = [
  'from-red-900/80 to-purple-900/80',
  'from-blue-900/80 to-indigo-900/80',
  'from-emerald-900/80 to-teal-900/80',
  'from-orange-900/80 to-red-900/80',
  'from-violet-900/80 to-fuchsia-900/80',
  'from-cyan-900/80 to-blue-900/80',
  'from-rose-900/80 to-pink-900/80',
  'from-amber-900/80 to-yellow-900/80',
];
const gradient = placeholderGradients[title.title.length % placeholderGradients.length];

const posterGradients = [
  'from-red-900 to-purple-900',
  'from-blue-900 to-indigo-900',
  'from-emerald-900 to-teal-900',
  'from-orange-900 to-red-900',
  'from-violet-900 to-fuchsia-900',
  'from-cyan-900 to-blue-900',
  'from-rose-900 to-pink-900',
  'from-amber-900 to-yellow-900',
];
const posterGradient = posterGradients[title.title.length % posterGradients.length];

const playerUrl = `/player/?type=movie&id=${title.tmdbId}`;
const watchUrl = `${SITE_URL}${playerUrl}`;
const schemaData = [
  movieSchema({
    title: title.title,
    overview: title.overview,
    poster_path: title.posterUrl,
    release_date: title.releaseDate,
    director: title.director,
    genre: title.genres,
    vote_average: title.rating,
  }),
  watchActionSchema(watchUrl, title.title, 'Movie'),
  breadcrumbSchema(breadcrumbs),
  faqSchema(faqs),
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={`Watch ${title.title} (${title.year}) Online Free in HD`}
    description={`Watch ${title.title} (${title.year}) online free in HD. ${title.overview.slice(0, 130)}... Stream on NetMirror — no sign-up required.`}
    canonical={`${SITE_URL}/movies/${title.slug}/`}
    ogType="video.movie"
  />
  <Schema slot="head" schema={schemaData} />

  <Header />

  <main>
    <!-- Backdrop Hero Area -->
    <section class="relative w-full min-h-[60vh] md:min-h-[70vh] overflow-hidden">
      <!-- Backdrop Image -->
      {title.backdropUrl && (
        <img src={title.backdropUrl} alt="" class="absolute inset-0 w-full h-full object-cover" loading="eager" />
      )}
      <div class={`absolute inset-0 bg-gradient-to-br ${gradient} ${title.backdropUrl ? 'opacity-40' : ''}`}></div>

      <!-- Dark Overlay Gradients -->
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg)] via-[var(--color-bg)]/60 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-bg)]/80 to-transparent"></div>

      <!-- Content Overlay -->
      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-8">
        <Breadcrumbs items={breadcrumbs} />

        <div class="flex flex-col md:flex-row gap-8 mt-4">
          <!-- Poster -->
          <div class="flex-shrink-0 w-48 md:w-64">
            <div class={`aspect-[2/3] rounded-xl overflow-hidden shadow-2xl bg-gradient-to-br ${posterGradient} relative`}>
              {title.posterUrl ? (
                <img src={title.posterUrl} alt={`${title.title} poster`} class="w-full h-full object-cover" loading="eager" width="256" height="384" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
              ) : null}
              <div class="w-full h-full flex items-center justify-center absolute inset-0" style={title.posterUrl ? 'display:none' : ''}>
                <span class="text-lg font-bold text-white/50 text-center px-3 leading-tight">{title.title}</span>
              </div>
            </div>
          </div>

          <!-- Info -->
          <div class="flex-1 flex flex-col justify-end">
            <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-4">
              {title.title}
            </h1>

            <!-- Meta Row -->
            <div class="flex flex-wrap items-center gap-3 mb-4">
              <span class="text-[var(--color-text-secondary)] font-medium">{title.year}</span>
              {title.runtime && (<>
                <span class="w-1 h-1 rounded-full bg-[var(--color-text-muted)]"></span>
                <span class="text-[var(--color-text-secondary)]">{title.runtime}</span>
              </>)}
              {title.rating > 0 && (<>
                <span class="w-1 h-1 rounded-full bg-[var(--color-text-muted)]"></span>
                <span class="flex items-center gap-1 text-yellow-400 font-semibold">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                  </svg>
                  {title.rating.toFixed(1)}
                </span>
              </>)}
              {title.status && (
                <span class="px-2.5 py-1 rounded text-xs font-medium bg-white/10 text-[var(--color-text-secondary)]">
                  {title.status}
                </span>
              )}
            </div>

            <!-- Genre Chips -->
            <div class="flex flex-wrap gap-2 mb-5">
              {title.genres.map(genre => (
                <a href={`/genre/${genre.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}/`} class="chip text-sm">
                  {genre}
                </a>
              ))}
            </div>

            <!-- Director -->
            {title.director && (
              <p class="text-[var(--color-text-secondary)] mb-4">
                <span class="text-[var(--color-text-muted)]">Directed by</span>
                <span class="text-white font-medium ml-1">{title.director}</span>
              </p>
            )}

            <!-- Overview -->
            <p class="text-[var(--color-text-secondary)] leading-relaxed max-w-3xl text-base md:text-lg mb-6">
              {title.overview}
            </p>

            <!-- Action Buttons -->
            <div class="flex items-center gap-3 flex-wrap">
              <a href={playerUrl} class="btn-primary px-6 py-2.5 rounded-lg text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                Watch Now
              </a>
              <a href={APK_UNIVERSAL_URL} download rel="noopener noreferrer" class="btn-glass px-5 py-2.5 rounded-lg text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                Download App
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Content Sections -->
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 space-y-16">

      <!-- Cast Section -->
      {title.cast.length > 0 && (
        <section>
          <h2 class="section-title mb-6">Cast</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4" id="cast-grid">
            {title.cast.map(member => (
              <div class="glass-card rounded-xl p-4 text-center" data-person-name={member.name}>
                <div class="w-16 h-16 mx-auto mb-3 rounded-full bg-gradient-to-br from-[var(--color-primary)]/30 to-[var(--color-accent)]/30 flex items-center justify-center overflow-hidden person-avatar">
                  <span class="text-xl font-bold text-white/60 person-initial">{member.name.charAt(0)}</span>
                </div>
                <p class="text-sm font-semibold text-white truncate">{member.name}</p>
                <p class="text-xs text-[var(--color-text-muted)] truncate mt-1">{member.role}</p>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Movie Details -->
      <section>
        <h2 class="section-title mb-4">Details</h2>
        <div class="glass-card rounded-xl overflow-hidden">
          <table class="w-full text-sm">
            <tbody>
              <tr class="border-b border-[var(--color-border)]">
                <td class="px-5 py-3 text-[var(--color-text-muted)] w-40">Release Date</td>
                <td class="px-5 py-3">{title.releaseDate || title.year} &middot; <a href={`/year/${title.year}/`} class="text-[var(--color-primary)] hover:underline">{title.year}</a></td>
              </tr>
              {title.runtime && (
                <tr class="border-b border-[var(--color-border)]">
                  <td class="px-5 py-3 text-[var(--color-text-muted)]">Runtime</td>
                  <td class="px-5 py-3">{title.runtime}</td>
                </tr>
              )}
              <tr class="border-b border-[var(--color-border)]">
                <td class="px-5 py-3 text-[var(--color-text-muted)]">Rating</td>
                <td class="px-5 py-3">{title.rating}/10</td>
              </tr>
              <tr class="border-b border-[var(--color-border)]">
                <td class="px-5 py-3 text-[var(--color-text-muted)]">Genres</td>
                <td class="px-5 py-3">
                  <div class="flex flex-wrap gap-2">
                    {titleGenres.map(g => (
                      <a href={`/genre/${g.slug}/`} class="text-[var(--color-primary)] hover:underline">{g.name}</a>
                    ))}
                  </div>
                </td>
              </tr>
              {title.languages.length > 0 && (
                <tr>
                  <td class="px-5 py-3 text-[var(--color-text-muted)]">Languages</td>
                  <td class="px-5 py-3">{title.languages.join(', ')}</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
      </section>

      <!-- Available Now (live official-platform data) -->
      <section>
        <h2 class="section-title mb-6">Available Now</h2>
        <div id="streaming-availability" data-title={title.title} data-year={title.year} data-type="movie">
          <div data-state="loading" class="flex items-center gap-2 text-sm text-[var(--color-text-muted)]">
            <div class="w-4 h-4 border-2 border-white/10 border-t-[var(--color-primary)] rounded-full animate-spin"></div>
            Checking official streaming platforms...
          </div>
          <div data-state="list" class="hidden flex flex-wrap gap-3"></div>
          <p data-state="empty" class="hidden text-sm text-[var(--color-text-muted)]">
            Not currently listed on a tracked streaming platform for your region.
          </p>
          <p data-state="error" class="hidden text-sm text-[var(--color-text-muted)]">
            Couldn't load official streaming info right now.
          </p>
        </div>
        <p class="mt-4 text-xs text-[var(--color-text-muted)]">
          Official, licensed streaming platforms — availability may vary by region.
        </p>
      </section>

      <!-- Trailer Section -->
      <section>
        <h2 class="section-title mb-6">Trailer</h2>
        {title.trailerUrl ? (
          <div class="aspect-video rounded-xl overflow-hidden glass-card">
            <iframe
              src={title.trailerUrl}
              title={`${title.title} Trailer`}
              class="w-full h-full"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        ) : (
          <div class="glass-card rounded-xl p-12 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mx-auto mb-4 text-[var(--color-text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            <p class="text-[var(--color-text-muted)] text-lg">Trailer coming soon</p>
            <p class="text-[var(--color-text-muted)] text-sm mt-2">Check back later for the official trailer.</p>
          </div>
        )}
      </section>

      <FAQSection faqs={faqs} />

      <!-- Related Titles -->
      {related.length > 0 && (
        <section>
          <h2 class="section-title mb-6">You Might Also Like</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
            {related.map(relatedTitle => (
              <TitleCard title={relatedTitle} />
            ))}
          </div>
        </section>
      )}

      <!-- Legal Disclaimer -->
      <section class="glass-card rounded-xl p-6">
        <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
          <strong class="text-[var(--color-text-secondary)]">Disclaimer:</strong> Net27 does not host, store, or distribute any copyrighted content. All information provided on this page, including movie details, cast, and streaming availability, is for informational purposes only. We help users discover titles and find legal streaming options. All trademarks, service marks, and content referenced belong to their respective owners. Streaming availability may vary by region and is subject to change.
        </p>
      </section>

    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  import { mountStreamingAvailability } from '../../lib/apis/streamingAvailability';
  mountStreamingAvailability('streaming-availability');

  document.querySelectorAll('[data-person-name]').forEach(el => {
    const name = el.getAttribute('data-person-name');
    if (!name) return;
    const avatar = el.querySelector('.person-avatar');
    if (!avatar) return;
    fetch(`/api/tmdb/person?name=${encodeURIComponent(name)}`)
      .then(r => r.json())
      .then(data => {
        if (data.profileUrl) {
          const img = document.createElement('img');
          img.src = data.profileUrl;
          img.alt = name;
          img.className = 'w-full h-full object-cover';
          img.loading = 'lazy';
          const initial = avatar.querySelector('.person-initial') as HTMLElement;
          if (initial) initial.style.display = 'none';
          avatar.appendChild(img);
        }
      })
      .catch(() => {});
  });
</script>
