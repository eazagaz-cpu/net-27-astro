---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import { sampleTitles } from '../../data/sampleTitles';
import { getBackdropUrl } from '../../lib/media';
import { SITE_URL } from '../../lib/seo';
import { APK_UNIVERSAL_URL } from '../../lib/constants';

export const getStaticPaths = (() => {
  return sampleTitles.map(title => ({
    params: { slug: title.slug },
    props: { title },
  }));
}) satisfies GetStaticPaths;

const { title } = Astro.props;
const backdropUrl = getBackdropUrl(title.backdrop);
const detailHref = title.type === 'movie' ? `/movies/${title.slug}/` : `/shows/${title.slug}/`;
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={`Watch ${title.title} (${title.year})`}
    description={`Watch ${title.title} on NetMirror. Choose a server to stream ${title.title} (${title.year}).`}
    canonical={`${SITE_URL}/watch/${title.slug}/`}
    noindex={true}
  />

  <main class="min-h-screen bg-black text-white relative">
    <!-- Top bar -->
    <div class="fixed top-0 left-0 right-0 z-50 bg-black/90 backdrop-blur-sm border-b border-white/5">
      <div class="flex items-center justify-between px-4 h-12">
        <a href={detailHref} class="flex items-center gap-2 text-sm text-[var(--color-muted)] hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          Back
        </a>
        <h1 class="text-sm font-medium truncate max-w-[50%]">{title.title}</h1>
        <div class="flex items-center gap-2">
          <span class="text-xs px-2 py-0.5 rounded bg-white/10 text-[var(--color-muted)]">Server 1</span>
          <a href="/" class="p-1 text-[var(--color-muted)] hover:text-white transition-colors" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Player area -->
    <div class="pt-12 flex flex-col items-center justify-center min-h-screen">
      {backdropUrl && (
        <div class="absolute inset-0 opacity-10">
          <img src={backdropUrl} alt="" class="w-full h-full object-cover" />
        </div>
      )}

      <div class="relative z-10 text-center px-4 max-w-lg">
        <h2 class="text-xl font-bold mb-2">Choose a server</h2>
        <p class="text-sm text-[var(--color-muted)] mb-6">Server 1 recommended · Server 2 is a fallback</p>

        <div class="flex items-center justify-center gap-4 mb-8">
          <button class="px-8 py-3 rounded-xl text-sm font-semibold text-white cursor-pointer transition-all hover:scale-105" style="background: var(--color-primary);">
            Server 1
          </button>
          <button class="px-8 py-3 rounded-xl text-sm font-semibold text-white cursor-pointer border border-white/15 hover:bg-white/5 transition-all">
            Server 2
          </button>
        </div>

        <div class="glass-card rounded-2xl p-6 text-left mb-6">
          <p class="text-sm text-[var(--color-muted)] mb-4">
            Streaming source is not configured for this title. Use the NetMirror app for the best experience.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href={APK_UNIVERSAL_URL} download class="btn-primary text-xs px-4 py-2 rounded-lg" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
              Download App
            </a>
            <a href={detailHref} class="btn-glass text-xs px-4 py-2 rounded-lg">
              More Info
            </a>
          </div>
        </div>

        <p class="text-[10px] text-[var(--color-text-muted)]">
          NetMirror does not host any content. Streams are provided by third-party services.
        </p>
      </div>
    </div>
  </main>
</BaseLayout>
