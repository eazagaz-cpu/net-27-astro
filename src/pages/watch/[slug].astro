---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import { sampleTitles } from '../../data/sampleTitles';
import { SITE_URL } from '../../lib/seo';
import { APK_UNIVERSAL_URL } from '../../lib/constants';

export const getStaticPaths = (() => {
  return sampleTitles.map(title => ({
    params: { slug: title.slug },
    props: { title },
  }));
}) satisfies GetStaticPaths;

const { title } = Astro.props;
const detailHref = title.type === 'movie' ? `/movies/${title.slug}/` : `/shows/${title.slug}/`;
const mediaType = title.type === 'movie' ? 'movie' : 'tv';
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={`Watch ${title.title} (${title.year})`}
    description={`Watch ${title.title} on NetMirror.`}
    canonical={`${SITE_URL}/watch/${title.slug}/`}
    noindex={true}
  />

  <main class="min-h-screen bg-black text-white">
    <!-- Top bar -->
    <div class="fixed top-0 left-0 right-0 z-50 bg-black/95 backdrop-blur-sm border-b border-white/5">
      <div class="flex items-center justify-between px-4 h-12">
        <a href={detailHref} class="flex items-center gap-2 text-sm text-zinc-400 hover:text-white transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          Back
        </a>
        <h1 class="text-sm font-medium truncate max-w-[40%]">{title.title}</h1>
        <div class="flex items-center gap-2">
          <select id="server-select" class="bg-white/10 text-xs text-white border border-white/10 rounded px-2 py-1 cursor-pointer">
            <option value="0">Server 1</option>
            <option value="1">Server 2</option>
          </select>
          <a href="/" class="p-1 text-zinc-400 hover:text-white" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- TV controls (for shows) -->
    {(title.type === 'show' || title.type === 'anime') && (
      <div id="tv-controls" class="fixed top-12 left-0 right-0 z-40 bg-black/90 border-b border-white/5 px-4 py-2">
        <div class="flex items-center gap-3">
          <select id="season-select" class="bg-white/10 text-xs text-white border border-white/10 rounded px-2 py-1 cursor-pointer">
            {title.seasons ? Array.from({length: title.seasons}, (_, i) => (
              <option value={i + 1}>Season {i + 1}</option>
            )) : <option value="1">Season 1</option>}
          </select>
          <select id="episode-select" class="bg-white/10 text-xs text-white border border-white/10 rounded px-2 py-1 cursor-pointer">
            {Array.from({length: Math.min(title.episodes || 20, 30)}, (_, i) => (
              <option value={i + 1}>Episode {i + 1}</option>
            ))}
          </select>
        </div>
      </div>
    )}

    <!-- Player container -->
    <div id="player-container" class={`w-full ${(title.type === 'show' || title.type === 'anime') ? 'pt-[88px]' : 'pt-12'}`} style="height:100vh;">
      <div id="player-loading" class="flex items-center justify-center h-full">
        <div class="text-center">
          <div class="w-10 h-10 border-2 border-white/20 border-t-[var(--color-primary)] rounded-full animate-spin mx-auto mb-4"></div>
          <p class="text-zinc-400 text-sm">Finding stream for {title.title}...</p>
        </div>
      </div>
      <iframe
        id="player-iframe"
        class="w-full hidden border-0"
        style={`height:calc(100vh - ${(title.type === 'show' || title.type === 'anime') ? '88px' : '48px'});`}
        allowfullscreen
        allow="autoplay; encrypted-media; picture-in-picture; fullscreen"
        referrerpolicy="origin"
      ></iframe>
      <!-- Fallback -->
      <div id="player-fallback" class="hidden flex items-center justify-center h-full">
        <div class="text-center px-4 max-w-lg">
          <h2 class="text-xl font-bold mb-2">Stream Unavailable</h2>
          <p class="text-sm text-zinc-400 mb-6">Could not find a stream. Try another server or use the app.</p>
          <div class="flex items-center justify-center gap-4">
            <a href={APK_UNIVERSAL_URL} download class="btn-primary text-xs px-6 py-2.5 rounded-lg" rel="noopener noreferrer">Download App</a>
            <a href={detailHref} class="btn-glass text-xs px-6 py-2.5 rounded-lg">Go Back</a>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script define:vars={{ titleName: title.title, mediaType, titleYear: title.year }}>
  let tmdbId = null;
  let season = 1;
  let episode = 1;

  function getEmbedUrl(serverIdx) {
    if (!tmdbId) return '';
    if (mediaType === 'movie') {
      return serverIdx === 0
        ? `https://embed.su/embed/movie/${tmdbId}`
        : `https://vidlink.pro/movie/${tmdbId}`;
    } else {
      return serverIdx === 0
        ? `https://embed.su/embed/tv/${tmdbId}/${season}/${episode}`
        : `https://vidlink.pro/tv/${tmdbId}/${season}/${episode}`;
    }
  }

  function loadPlayer(serverIdx) {
    const iframe = document.getElementById('player-iframe');
    const loading = document.getElementById('player-loading');
    const fallback = document.getElementById('player-fallback');
    const url = getEmbedUrl(serverIdx);

    if (!url || !iframe) {
      if (loading) loading.classList.add('hidden');
      if (fallback) fallback.classList.remove('hidden');
      return;
    }

    iframe.src = url;
    iframe.classList.remove('hidden');
    if (loading) loading.classList.add('hidden');
    if (fallback) fallback.classList.add('hidden');
  }

  // Server selector
  const serverSelect = document.getElementById('server-select');
  if (serverSelect) {
    serverSelect.addEventListener('change', () => loadPlayer(parseInt(serverSelect.value)));
  }

  // Season/episode selectors
  const seasonSelect = document.getElementById('season-select');
  const episodeSelect = document.getElementById('episode-select');
  if (seasonSelect) {
    seasonSelect.addEventListener('change', () => { season = parseInt(seasonSelect.value); loadPlayer(parseInt(serverSelect?.value || '0')); });
  }
  if (episodeSelect) {
    episodeSelect.addEventListener('change', () => { episode = parseInt(episodeSelect.value); loadPlayer(parseInt(serverSelect?.value || '0')); });
  }

  // Search TMDB for this title to get the numeric ID
  // Try multiple search strategies for best match
  async function findTmdbId() {
    // Strategy 1: Search by exact title
    let res = await fetch(`/api/tmdb/search?q=${encodeURIComponent(titleName)}`);
    let data = await res.json();
    let items = data.items || [];

    let match = items.find(i => i.title.toLowerCase() === titleName.toLowerCase() && (!titleYear || i.year === titleYear))
      || items.find(i => i.title.toLowerCase() === titleName.toLowerCase())
      || items.find(i => i.title.toLowerCase().includes(titleName.toLowerCase().split(':')[0].split(' - ')[0].trim()));

    if (match) return match.id;

    // Strategy 2: Search with first 2 words only
    const shortName = titleName.split(' ').slice(0, 2).join(' ');
    if (shortName !== titleName) {
      res = await fetch(`/api/tmdb/search?q=${encodeURIComponent(shortName)}`);
      data = await res.json();
      items = data.items || [];
      if (items.length > 0) return items[0].id;
    }

    // Strategy 3: Use first result from any search
    if ((data.items || []).length > 0) return data.items[0].id;

    return null;
  }

  findTmdbId().then(id => {
    if (id) {
      tmdbId = id;
      loadPlayer(0);
    } else {
      const loading = document.getElementById('player-loading');
      const fallback = document.getElementById('player-fallback');
      if (loading) loading.classList.add('hidden');
      if (fallback) fallback.classList.remove('hidden');
    }
  }).catch(() => {
      const loading = document.getElementById('player-loading');
      const fallback = document.getElementById('player-fallback');
      if (loading) loading.classList.add('hidden');
      if (fallback) fallback.classList.remove('hidden');
    });
</script>
