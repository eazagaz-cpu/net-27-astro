---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';
import Schema from '../../components/Schema.astro';
import TitleCard from '../../components/TitleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQSection from '../../components/FAQSection.astro';
import { studios, getStudioTitles } from '../../data/entities';
import { genres } from '../../data/sampleTitles';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';
import { SITE_URL } from '../../lib/seo';

export const getStaticPaths = (() => {
  return studios.map(studio => ({
    params: { slug: studio.slug },
    props: { studio },
  }));
}) satisfies GetStaticPaths;

const { studio } = Astro.props;
const titles = getStudioTitles(studio);
const movies = titles.filter(t => t.type === 'movie');
const shows = titles.filter(t => t.type === 'show' || t.type === 'anime');
const otherStudios = studios.filter(s => s.slug !== studio.slug);
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Studios', href: '/' },
  { label: studio.name, href: `/studio/${studio.slug}/` },
];

const faqs = [
  { question: `What is ${studio.name}?`, answer: `${studio.name} is a film and television production company founded in ${studio.founded}, headquartered in ${studio.headquarters}. ${studio.description}` },
  { question: `What movies has ${studio.name} produced?`, answer: `${studio.name} has produced ${titles.length} titles in our database, including ${titles.slice(0, 3).map(t => t.title).join(', ')}${titles.length > 3 ? ' and more' : ''}.` },
  { question: `Where is ${studio.name} based?`, answer: `${studio.name} is headquartered in ${studio.headquarters}. The studio was founded in ${studio.founded}.` },
  { question: `What genres does ${studio.name} specialize in?`, answer: `${studio.name} produces content across multiple genres including ${[...new Set(titles.flatMap(t => t.genres))].slice(0, 4).join(', ')}. ${studio.description}` },
  { question: `Where can I watch ${studio.name} titles?`, answer: `${studio.name} titles are available on various streaming platforms including ${[...new Set(titles.flatMap(t => t.platforms))].slice(0, 4).join(', ')}. Check individual title pages for specific platform availability.` },
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={`${studio.name} - Movies & Shows | Official Filmography`}
    description={`Explore ${studio.name}'s filmography. Browse ${titles.length} movies, TV shows, and anime produced by ${studio.name}. Founded ${studio.founded} in ${studio.headquarters}.`}
    canonical={`${SITE_URL}/studio/${studio.slug}/`}
  />
  <Schema slot="head" schema={[breadcrumbSchema(breadcrumbs), faqSchema(faqs)]} />

  <Header />

  <main class="min-h-screen">
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-accent)]/10 to-[var(--color-primary)]/10"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-primary)] to-transparent"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-4 pt-24 pb-10">
        <Breadcrumbs items={breadcrumbs} />
        <div class="flex items-start gap-6 mt-4">
          <div class="hidden sm:flex shrink-0 w-20 h-20 rounded-2xl bg-gradient-to-br from-[var(--color-primary)]/20 to-[var(--color-accent)]/20 border border-[var(--color-border)] items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-white/80" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 4V2a1 1 0 011-1h8a1 1 0 011 1v2m-2 4h.01M12 12h.01M8 12h.01M12 16h.01M8 16h.01M16 12h.01M16 16h.01M7 20h10a2 2 0 002-2V8a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold leading-tight">
              <span class="gradient-text">{studio.name}</span>
            </h1>
            <div class="mt-3 flex flex-wrap gap-4 text-sm text-[var(--color-text-muted)]">
              <span>Founded: {studio.founded}</span>
              <span>&middot;</span>
              <span>{studio.headquarters}</span>
              <span>&middot;</span>
              <span>{titles.length} Titles</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-7xl px-4 py-12 space-y-16">

      <section>
        <h2 class="section-title mb-4">About {studio.name}</h2>
        <p class="text-[var(--color-text-secondary)] leading-relaxed max-w-4xl">
          {studio.description} Founded in {studio.founded} and headquartered in {studio.headquarters}, {studio.name} has built a reputation for producing compelling entertainment that resonates with global audiences. The studio's catalog includes {movies.length} movies and {shows.length} television series, spanning genres from {[...new Set(titles.flatMap(t => t.genres))].slice(0, 3).join(' to ')}.
        </p>
        <p class="text-[var(--color-text-secondary)] leading-relaxed max-w-4xl mt-4">
          With a commitment to creative excellence and innovative storytelling, {studio.name} continues to deliver content that entertains, challenges, and inspires audiences worldwide. Their titles are available across leading streaming platforms, making their work accessible to viewers everywhere.
        </p>
      </section>

      {titles.length > 0 && (
        <section>
          <h2 class="section-title mb-6">Filmography</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
            {titles.map(title => <TitleCard title={title} />)}
          </div>
        </section>
      )}

      <section>
        <h2 class="section-title mb-4">Key Details</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="glass-card rounded-xl p-5">
            <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider mb-1">Founded</p>
            <p class="text-xl font-bold">{studio.founded}</p>
          </div>
          <div class="glass-card rounded-xl p-5">
            <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider mb-1">Headquarters</p>
            <p class="text-xl font-bold">{studio.headquarters}</p>
          </div>
          <div class="glass-card rounded-xl p-5">
            <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider mb-1">Titles</p>
            <p class="text-xl font-bold">{titles.length}</p>
          </div>
          <div class="glass-card rounded-xl p-5">
            <p class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider mb-1">Genres</p>
            <p class="text-xl font-bold">{[...new Set(titles.flatMap(t => t.genres))].length}</p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="section-title mb-6">Other Studios</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {otherStudios.map(s => (
            <a href={`/studio/${s.slug}/`} class="glass-card rounded-xl p-5 hover:border-[var(--color-primary)]/50 transition-all">
              <h3 class="font-semibold mb-1 hover:text-[var(--color-primary)] transition-colors">{s.name}</h3>
              <p class="text-xs text-[var(--color-text-muted)] mb-2">{s.headquarters} &middot; Est. {s.founded}</p>
              <p class="text-sm text-[var(--color-text-secondary)] line-clamp-2">{s.description}</p>
            </a>
          ))}
        </div>
      </section>

      <section>
        <h2 class="section-title mb-6">Browse by Genre</h2>
        <div class="flex flex-wrap gap-3">
          {genres.slice(0, 10).map(g => (
            <a href={`/genre/${g.slug}/`} class="chip">{g.name}</a>
          ))}
        </div>
      </section>

      <FAQSection faqs={faqs} />

      <section class="glass-card rounded-xl p-6">
        <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
          <strong class="text-[var(--color-text-secondary)]">Disclaimer:</strong> Net27 does not host or distribute copyrighted content. {studio.name} and all associated trademarks belong to their respective owners. Information is for discovery purposes only. Last updated: {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}.
        </p>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>
