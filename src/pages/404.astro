---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="404 - Page Not Found"
    description="The page you're looking for doesn't exist or has been moved."
    noindex={true}
  />

  <Header />

  <main class="min-h-screen pt-20 flex items-center justify-center">
    <div class="max-w-2xl mx-auto px-4 py-16 text-center">
      <div class="mb-8">
        <span class="text-8xl md:text-[10rem] font-black gradient-text leading-none">404</span>
      </div>

      <h1 class="text-2xl md:text-3xl font-bold mb-4">
        Oops! This Page Has Vanished
      </h1>

      <p class="text-[var(--color-text-secondary)] mb-8 max-w-md mx-auto">
        The page you're looking for doesn't exist, may have been moved, or is temporarily unavailable. Let's get you back on track.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Go Home
        </a>
        <a href="/search/" class="btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          Search Titles
        </a>
      </div>

      <div class="mt-16 grid grid-cols-3 gap-4 max-w-sm mx-auto opacity-30">
        <div class="aspect-[2/3] rounded-lg bg-[var(--color-bg-card)]"></div>
        <div class="aspect-[2/3] rounded-lg bg-[var(--color-bg-card)] -translate-y-4"></div>
        <div class="aspect-[2/3] rounded-lg bg-[var(--color-bg-card)]"></div>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
