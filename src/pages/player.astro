---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import { SITE_URL } from '../lib/seo';
---

<BaseLayout>
  <SEOHead slot="head" title="Watch Now — NetMirror Player" description="Watch movies and TV shows on NetMirror. Multiple servers for smooth playback." canonical={`${SITE_URL}/player/`} noindex={true} />

  <main class="player-shell">
    <!-- Top bar -->
    <div class="player-topbar">
      <div class="flex items-center justify-between px-3 sm:px-4 h-12">
        <button onclick="history.back()" class="flex items-center gap-2 text-sm text-zinc-400 hover:text-white cursor-pointer" aria-label="Go back">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          <span class="hidden sm:inline">Back</span>
        </button>
        <h1 class="text-xs sm:text-sm font-medium truncate max-w-[35%] sm:max-w-[40%]" id="player-title">Loading...</h1>
        <div class="flex items-center gap-1.5 sm:gap-2">
          <select id="server-select" class="bg-black text-[11px] sm:text-xs text-white border border-white/10 rounded px-1.5 sm:px-2 py-1 cursor-pointer" aria-label="Select server"></select>
          <!-- Language selector -->
          <div class="relative" id="lang-wrapper">
            <button id="lang-btn" class="flex items-center gap-1 bg-black text-[11px] sm:text-xs text-white border border-white/10 rounded px-1.5 sm:px-2 py-1 cursor-pointer hover:border-white/25 transition-colors" aria-label="Select audio language" title="Audio / Subtitle language">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-zinc-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
              <span id="lang-label" class="max-w-[56px] truncate">Default</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-zinc-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div id="lang-dropdown" class="lang-dropdown hidden absolute right-0 top-full mt-1 bg-[#111] border border-white/10 rounded-lg shadow-2xl min-w-[150px] max-h-60 overflow-y-auto">
              <!-- populated by JS -->
            </div>
          </div>
          <button id="report-btn" class="text-zinc-500 hover:text-zinc-300 cursor-pointer p-1 transition-colors" aria-label="Report issue" title="Report problem">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
          </button>
          <a href="/" class="p-1 text-zinc-400 hover:text-white" aria-label="Close player">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- TV controls -->
    <div id="tv-controls" class="fixed top-12 left-0 right-0 z-40 bg-black/90 border-b border-white/5 px-4 py-2 hidden">
      <div class="flex items-center gap-3">
        <select id="season-select" class="bg-black text-xs text-white border border-white/10 rounded px-2 py-1 cursor-pointer" aria-label="Select season"></select>
        <select id="episode-select" class="bg-black text-xs text-white border border-white/10 rounded px-2 py-1 cursor-pointer" aria-label="Select episode">
          <option value="1">Episode 1</option>
        </select>
      </div>
    </div>

    <!-- Player iframe container -->
    <div id="player-container" class="player-frame-wrap pt-12">

      <!-- Loading state -->
      <div id="player-loading" class="flex items-center justify-center h-full">
        <div class="text-center">
          <div class="w-10 h-10 border-2 border-white/15 border-t-white/80 rounded-full animate-spin mx-auto mb-5"></div>
          <p class="text-sm font-medium text-white mb-1.5">Resolving stream...</p>
          <p class="text-xs text-zinc-500" id="loading-movie-title"></p>
        </div>
      </div>

      <!-- Server chooser (first visit — no saved preference) -->
      <div id="player-chooser" class="hidden flex items-center justify-center h-full">
        <div class="text-center px-4 max-w-sm w-full">
          <h2 class="text-xl font-bold mb-1.5">Choose a server</h2>
          <p class="text-sm text-zinc-500 mb-8">Server 1 is recommended · others are fallbacks</p>
          <div class="grid grid-cols-2 gap-3" id="chooser-btns"></div>
        </div>
      </div>

      <!-- Iframe (classic server mode) -->
      <iframe
        id="player-iframe"
        class="player-frame hidden"
        style="height:calc(100svh - 48px);"
        allowfullscreen
        allow="autoplay; fullscreen; picture-in-picture; encrypted-media"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>

      <!-- Video element (stream mode — ad-free) -->
      <video
        id="player-video"
        class="player-frame hidden"
        style="height:calc(100svh - 48px);background:#000;"
        controls
        controlslist="nodownload"
        crossorigin="anonymous"
        playsinline
      ></video>

      <!-- Server/timeout error (State B) -->
      <div id="player-fallback" class="hidden flex items-center justify-center h-full">
        <div class="text-center px-4 max-w-lg">
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-red-500/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
            </svg>
          </div>
          <h2 class="text-lg font-bold mb-2">Playback Unavailable</h2>
          <p class="text-sm text-zinc-400 mb-6">This server is not responding right now. Please retry or switch to another server.</p>
          <div class="flex items-center justify-center gap-3 flex-wrap">
            <button id="fallback-retry" class="btn-primary text-xs px-5 py-2.5 rounded-lg cursor-pointer">Retry</button>
            <button id="fallback-switch" class="btn-glass text-xs px-5 py-2.5 rounded-lg cursor-pointer">Switch Server</button>
            <button onclick="history.back()" class="btn-glass text-xs px-5 py-2.5 rounded-lg cursor-pointer">Back</button>
          </div>
          <p id="trailer-link" class="hidden mt-4"></p>
        </div>
      </div>

      <!-- Iframe blocked (State C) -->
      <div id="player-blocked" class="hidden flex items-center justify-center h-full">
        <div class="text-center px-4 max-w-lg">
          <div class="w-12 h-12 mx-auto mb-4 rounded-full bg-yellow-500/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
            </svg>
          </div>
          <h2 class="text-lg font-bold mb-2">Player Blocked</h2>
          <p class="text-sm text-zinc-400 mb-6">This server cannot be loaded in the current player. Please switch to another server.</p>
          <div class="flex items-center justify-center gap-3">
            <button id="blocked-switch" class="btn-primary text-xs px-5 py-2.5 rounded-lg cursor-pointer">Switch Server</button>
            <button onclick="history.back()" class="btn-glass text-xs px-5 py-2.5 rounded-lg cursor-pointer">Back</button>
          </div>
        </div>
      </div>

      <!-- Title not found / metadata error (State A) -->
      <div id="player-notfound" class="hidden flex items-center justify-center h-full">
        <div class="text-center px-4 max-w-md">
          <h2 class="text-lg font-bold mb-2">Title Not Found</h2>
          <p class="text-sm text-zinc-400 mb-6">We could not find details for this title. Please go back and choose another title.</p>
          <div class="flex items-center justify-center gap-3">
            <button onclick="history.back()" class="btn-primary text-xs px-5 py-2.5 rounded-lg cursor-pointer">Back</button>
            <a href="/search/" class="btn-glass text-xs px-5 py-2.5 rounded-lg">Search Titles</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Report modal -->
    <div id="report-modal" class="fixed inset-0 z-[60] bg-black/80 backdrop-blur-sm hidden flex items-center justify-center p-4">
      <div class="bg-[#111] border border-white/10 rounded-2xl p-5 w-full max-w-sm">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-bold">Report Problem</h3>
          <button id="report-close" class="text-zinc-500 hover:text-white cursor-pointer" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
        <div class="space-y-2" id="report-options">
          <button data-issue="not_playing" class="report-option">Server not playing</button>
          <button data-issue="buffering" class="report-option">Buffering</button>
          <button data-issue="black_screen" class="report-option">Black screen</button>
          <button data-issue="wrong_title" class="report-option">Wrong title</button>
          <button data-issue="audio" class="report-option">Audio issue</button>
          <button data-issue="subtitle" class="report-option">Subtitle issue</button>
        </div>
        <div id="report-toast" class="hidden mt-4 p-3 rounded-lg bg-green-500/10 border border-green-500/20">
          <p class="text-xs text-green-400 text-center">Thanks for your feedback.</p>
          <button id="report-try-next" class="mt-2 w-full text-xs text-center text-[var(--color-primary)] hover:underline cursor-pointer">Switch server</button>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .player-shell { min-height: 100svh; background: #000; overflow: hidden; }
  .player-topbar { position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(0,0,0,0.95); backdrop-filter: blur(8px); border-bottom: 1px solid rgba(255,255,255,0.05); }
  .player-frame-wrap { width: 100%; height: 100svh; background: #000; }
  .player-frame { width: 100%; height: 100%; border: 0; background: #000; }
  .report-option { display: block; width: 100%; text-align: left; padding: 10px 14px; border-radius: 10px; font-size: 13px; color: #ccc; background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.06); cursor: pointer; transition: all 0.15s; }
  .report-option:hover { background: rgba(255,255,255,0.08); color: #fff; border-color: rgba(255,255,255,0.12); }
  #player-fallback, #player-blocked, #player-notfound, #player-loading, #player-chooser { height: calc(100svh - 48px); }
  .chooser-btn { padding: 18px 12px; border-radius: 12px; font-size: 14px; font-weight: 600; cursor: pointer; transition: opacity 0.15s, transform 0.1s; border: none; width: 100%; }
  .chooser-btn:hover { opacity: 0.85; transform: translateY(-1px); }
  .chooser-btn:active { transform: translateY(0); }
  .chooser-btn.s-primary { background: var(--color-primary); color: #fff; }
  .chooser-btn.s-alt { background: rgba(255,255,255,0.07); color: #fff; border: 1px solid rgba(255,255,255,0.1); }
  .lang-dropdown { z-index: 55; }
  .lang-opt { display: flex; align-items: center; justify-content: space-between; width: 100%; padding: 8px 12px; font-size: 12px; color: #ccc; background: transparent; border: none; cursor: pointer; transition: background 0.1s; text-align: left; }
  .lang-opt:hover { background: rgba(255,255,255,0.06); color: #fff; }
  .lang-opt.active { color: var(--color-primary); }
</style>

<script>
  import Hls from 'hls.js';
  import { getServers } from '../lib/player/servers';
  import { applySandbox } from '../lib/player/iframePolicy';
  import { loadSavedServer, saveSelectedServer, hasSavedServer } from '../lib/player/serverMemory';
  import { LANGUAGES, loadLang, saveLang, buildUrlWithLang } from '../lib/player/languages';
  import { reportIssue } from '../lib/serverQuality';
  import type { ReportType } from '../lib/serverQuality';

  // ── URL params ─────────────────────────────────────────────────────────────
  const params = new URLSearchParams(window.location.search);
  const type = (params.get('type') || 'movie') as 'movie' | 'tv';
  const id = params.get('id') || '';
  let season = parseInt(params.get('s') || '1');
  let episode = parseInt(params.get('e') || '1');

  // ── State ──────────────────────────────────────────────────────────────────
  let currentServerIdx = 0;
  let currentLang = 'default';
  let currentStreamMode = false;
  let loadTimeoutTimer: ReturnType<typeof setTimeout> | null = null;
  let playerConfirmed = false;
  let hlsInstance: Hls | null = null;

  const LOAD_TIMEOUT = 15000; // 15s: if onload never fires → show error (no auto-switch)

  // ── Block external popups from parent window context ───────────────────────
  const _origOpen = window.open;
  window.open = function(url?: string | URL, target?: string, features?: string): WindowProxy | null {
    const href = url ? url.toString() : '';
    if (!href || href.startsWith(location.origin) || href.startsWith('/') || href.startsWith('#')) {
      return _origOpen.call(window, url, target, features);
    }
    return null;
  };

  // ── DOM helpers ────────────────────────────────────────────────────────────
  function hideAllStates() {
    ['player-loading', 'player-iframe', 'player-video', 'player-fallback', 'player-blocked', 'player-notfound', 'player-chooser']
      .forEach(elId => document.getElementById(elId)?.classList.add('hidden'));
  }

  type ErrorVariant = 'timeout' | 'blocked' | 'metadata';

  function setState(state: 'loading' | 'ready' | 'error' | 'chooser', variant?: ErrorVariant) {
    hideAllStates();
    if (state === 'chooser') {
      document.getElementById('player-chooser')?.classList.remove('hidden');
    } else if (state === 'loading') {
      document.getElementById('player-loading')?.classList.remove('hidden');
    } else if (state === 'ready') {
      const elId = currentStreamMode ? 'player-video' : 'player-iframe';
      document.getElementById(elId)?.classList.remove('hidden');
    } else {
      if (variant === 'metadata') {
        document.getElementById('player-notfound')?.classList.remove('hidden');
      } else if (variant === 'blocked') {
        document.getElementById('player-blocked')?.classList.remove('hidden');
      } else {
        document.getElementById('player-fallback')?.classList.remove('hidden');
      }
    }
  }

  function clearLoadTimeout() {
    if (loadTimeoutTimer) { clearTimeout(loadTimeoutTimer); loadTimeoutTimer = null; }
  }

  // ── Server chooser (first visit) ──────────────────────────────────────────
  function populateChooser() {
    const container = document.getElementById('chooser-btns');
    if (!container) return;
    const servers = getServers({ type, id, season, episode });
    container.innerHTML = servers.map((srv, i) =>
      `<button class="chooser-btn ${i === 0 ? 's-primary' : 's-alt'}" data-idx="${i}">${srv.name}</button>`
    ).join('');
    container.querySelectorAll('.chooser-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        loadPlayer(parseInt((btn as HTMLElement).dataset.idx || '0'));
      });
    });
  }

  // ── Server list + dropdown ─────────────────────────────────────────────────
  function populateServers() {
    const select = document.getElementById('server-select') as HTMLSelectElement;
    if (!select) return;
    const servers = getServers({ type, id, season, episode });
    select.innerHTML = servers.map((srv, i) =>
      `<option value="${i}">${srv.name}</option>`
    ).join('');
    select.value = String(currentServerIdx);
  }

  // ── HLS stream loader (stream mode) ───────────────────────────────────────
  async function loadHLSStream(streamUrl: string, subtitles: { url: string; lang: string }[]) {
    const video = document.getElementById('player-video') as HTMLVideoElement;
    if (!video) return;

    // Remove old subtitle tracks
    Array.from(video.querySelectorAll('track')).forEach(t => t.remove());

    if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }

    if (Hls.isSupported()) {
      hlsInstance = new Hls({ enableWorker: true });
      hlsInstance.loadSource(streamUrl);
      hlsInstance.attachMedia(video);

      hlsInstance.on(Hls.Events.MANIFEST_PARSED, () => {
        playerConfirmed = true;
        clearLoadTimeout();
        setState('ready');
        video.play().catch(() => {});
      });

      hlsInstance.on(Hls.Events.ERROR, (_e: unknown, data: { fatal: boolean }) => {
        if (data.fatal) { clearLoadTimeout(); setState('error', 'timeout'); }
      });
    } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
      // Safari native HLS
      video.src = streamUrl;
      video.addEventListener('loadedmetadata', () => {
        playerConfirmed = true;
        clearLoadTimeout();
        setState('ready');
      }, { once: true });
      video.play().catch(() => {});
    } else {
      clearLoadTimeout();
      setState('error', 'timeout');
      return;
    }

    // Attach external subtitle tracks
    subtitles.forEach(sub => {
      const track = document.createElement('track');
      track.kind = 'subtitles';
      track.label = sub.lang;
      track.src = sub.url;
      if (sub.lang === 'English') track.default = true;
      video.appendChild(track);
    });
  }

  // ── Core: load a server by index ───────────────────────────────────────────
  function loadPlayer(serverIdx: number) {
    const servers = getServers({ type, id, season, episode });
    if (serverIdx < 0 || serverIdx >= servers.length) serverIdx = 0;
    currentServerIdx = serverIdx;
    playerConfirmed = false;

    if (!id) { setState('error', 'metadata'); return; }

    const srv = servers[serverIdx];
    currentStreamMode = srv.streamMode;

    clearLoadTimeout();

    // Clean up previous playback
    const iframe = document.getElementById('player-iframe') as HTMLIFrameElement;
    const video  = document.getElementById('player-video')  as HTMLVideoElement;
    if (iframe) iframe.removeAttribute('src');
    if (video)  { video.pause(); video.removeAttribute('src'); video.load(); }
    if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }

    setState('loading');
    saveSelectedServer(type, id, serverIdx);

    const select = document.getElementById('server-select') as HTMLSelectElement;
    if (select) select.value = String(serverIdx);

    if (srv.streamMode) {
      // ── Stream mode: resolve via /api/stream ──────────────────────────────
      loadTimeoutTimer = setTimeout(() => {
        loadTimeoutTimer = null;
        if (!playerConfirmed) setState('error', 'timeout');
      }, LOAD_TIMEOUT);

      fetch(`/api/stream?type=${encodeURIComponent(type)}&id=${encodeURIComponent(id)}&s=${season}&e=${episode}`)
        .then(r => r.json())
        .then((data: { sources?: { url: string; quality: string }[]; subtitles?: { url: string; lang: string }[]; error?: string }) => {
          if (!data.sources?.length) { clearLoadTimeout(); setState('error', 'timeout'); return; }
          const src = data.sources.find(s => s.quality === 'auto') || data.sources[0];
          loadHLSStream(src.url, data.subtitles || []);
        })
        .catch(() => { clearLoadTimeout(); setState('error', 'timeout'); });

    } else {
      // ── Iframe mode: existing behavior ────────────────────────────────────
      if (!iframe) { setState('error', 'metadata'); return; }
      applySandbox(iframe, srv.sandboxMode);

      requestAnimationFrame(() => {
        iframe.src = buildUrlWithLang(srv.url, currentLang);

        loadTimeoutTimer = setTimeout(() => {
          loadTimeoutTimer = null;
          if (!playerConfirmed) setState('error', 'timeout');
        }, LOAD_TIMEOUT);

        iframe.onload = () => {
          clearLoadTimeout();
          if (!playerConfirmed) setState('ready');
        };
      });
    }
  }

  // ── Language UI ────────────────────────────────────────────────────────────
  function populateLangDropdown() {
    const dropdown = document.getElementById('lang-dropdown');
    if (!dropdown) return;
    dropdown.innerHTML = LANGUAGES.map(l =>
      `<button class="lang-opt${currentLang === l.code ? ' active' : ''}" data-code="${l.code}">
        <span>${l.label}</span>
        ${currentLang === l.code ? '<svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>' : '<span class="w-3"></span>'}
      </button>`
    ).join('');
    dropdown.querySelectorAll('.lang-opt').forEach(btn => {
      btn.addEventListener('click', () => {
        setLang((btn as HTMLElement).dataset.code || 'default');
      });
    });
  }

  function updateLangLabel() {
    const found = LANGUAGES.find(l => l.code === currentLang);
    const el = document.getElementById('lang-label');
    if (el) el.textContent = found?.label || 'Default';
  }

  function setLang(code: string) {
    currentLang = code;
    saveLang(code);
    updateLangLabel();
    document.getElementById('lang-dropdown')?.classList.add('hidden');
    loadPlayer(currentServerIdx);
  }

  const langBtn = document.getElementById('lang-btn');
  const langDropdown = document.getElementById('lang-dropdown');
  langBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = langDropdown?.classList.contains('hidden');
    langDropdown?.classList.toggle('hidden', !isHidden);
    if (isHidden) populateLangDropdown();
  });
  document.addEventListener('click', (e) => {
    if (!document.getElementById('lang-wrapper')?.contains(e.target as Node)) {
      langDropdown?.classList.add('hidden');
    }
  });

  // ── Advance to next server (manual only) ───────────────────────────────────
  function switchServer() {
    const servers = getServers({ type, id, season, episode });
    const next = (currentServerIdx + 1) % servers.length;
    loadPlayer(next);
  }

  // ── postMessage from embed providers ──────────────────────────────────────
  window.addEventListener('message', (event) => {
    const d = event.data;
    if (!d || typeof d !== 'object') return;

    const isError =
      d.type === 'error' || d.event === 'error' ||
      d.status === 404 || d.code === 404 ||
      d.type === 'player:error' || d.type === 'content_not_found' ||
      d.reason === 'not_found' || d.error === true ||
      d.type === 'unavailable' || d.available === false ||
      d.message === 'unavailable' || d.event === 'unavailable';

    const isPlaying =
      d.event === 'play' || d.event === 'playing' || d.event === 'timeupdate' ||
      d.event === 'canplay' || d.event === 'loadeddata' || d.event === 'loadedmetadata' ||
      d.type === 'timeupdate' || d.type === 'play' || d.type === 'playing' ||
      d.type === 'playerReady' || d.type === 'ready' || d.type === 'canplay' ||
      d.type === 'loaded' || d.type === 'hlsready' || d.type === 'mediaready' ||
      d.action === 'play' ||
      (d.currentTime !== undefined && Number(d.currentTime) > 0);

    if (isError && !playerConfirmed) {
      clearLoadTimeout();
      setState('error', 'timeout');
    } else if (isPlaying) {
      playerConfirmed = true;
      clearLoadTimeout();
      if (!currentStreamMode) {
        const iframe = document.getElementById('player-iframe') as HTMLIFrameElement;
        if (iframe?.classList.contains('hidden')) setState('ready');
      }
    }
  });

  // ── Event listeners ────────────────────────────────────────────────────────
  const serverSelect = document.getElementById('server-select') as HTMLSelectElement;
  if (serverSelect) {
    serverSelect.addEventListener('change', () => {
      const idx = parseInt(serverSelect.value);
      saveSelectedServer(type, id, idx);
      loadPlayer(idx);
    });
  }

  document.getElementById('fallback-retry')?.addEventListener('click', () => {
    loadPlayer(currentServerIdx);
  });
  document.getElementById('fallback-switch')?.addEventListener('click', switchServer);
  document.getElementById('blocked-switch')?.addEventListener('click', switchServer);

  const seasonSelect = document.getElementById('season-select') as HTMLSelectElement;
  const episodeSelect = document.getElementById('episode-select') as HTMLSelectElement;

  if (seasonSelect) {
    seasonSelect.addEventListener('change', () => {
      season = parseInt(seasonSelect.value);
      populateServers();
      loadPlayer(currentServerIdx);
    });
  }
  if (episodeSelect) {
    episodeSelect.addEventListener('change', () => {
      episode = parseInt(episodeSelect.value);
      populateServers();
      loadPlayer(currentServerIdx);
    });
  }

  // ── Report system ──────────────────────────────────────────────────────────
  const reportModal = document.getElementById('report-modal');
  const reportToast = document.getElementById('report-toast');

  document.getElementById('report-btn')?.addEventListener('click', () => {
    if (reportModal) reportModal.classList.remove('hidden');
    if (reportToast) reportToast.classList.add('hidden');
    document.getElementById('report-options')?.classList.remove('hidden');
  });
  document.getElementById('report-close')?.addEventListener('click', () => {
    if (reportModal) reportModal.classList.add('hidden');
  });
  reportModal?.addEventListener('click', (e) => {
    if (e.target === reportModal) reportModal.classList.add('hidden');
  });

  document.querySelectorAll('.report-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const issue = ((btn as HTMLElement).dataset.issue || 'not_playing') as ReportType;
      const srv = getServers({ type, id, season, episode })[currentServerIdx];
      if (srv) reportIssue(srv.id, issue);
      if (reportToast) reportToast.classList.remove('hidden');
      document.getElementById('report-options')?.classList.add('hidden');
    });
  });

  document.getElementById('report-try-next')?.addEventListener('click', () => {
    if (reportModal) reportModal.classList.add('hidden');
    switchServer();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && reportModal && !reportModal.classList.contains('hidden')) {
      reportModal.classList.add('hidden');
    }
  });

  // ── Fullscreen: hide topbar ────────────────────────────────────────────────
  function onFullscreenChange() {
    const isFs = !!document.fullscreenElement;
    const topbar = document.querySelector('.player-topbar') as HTMLElement;
    if (topbar) topbar.style.display = isFs ? 'none' : '';
  }
  document.addEventListener('fullscreenchange', onFullscreenChange);
  document.addEventListener('webkitfullscreenchange', onFullscreenChange);

  // ── Init ───────────────────────────────────────────────────────────────────
  if (id) {
    currentLang = loadLang();
    updateLangLabel();
    currentServerIdx = loadSavedServer(type, id);
    populateServers();

    const firstVisit = !hasSavedServer(type, id);

    fetch(`/api/tmdb/details?type=${type}&id=${id}`)
      .then(r => r.json())
      .then(data => {
        if (data.title) {
          const el = document.getElementById('player-title');
          if (el) el.textContent = data.title;
          document.title = `Watch ${data.title} | NetMirror`;
          const movieTitleEl = document.getElementById('loading-movie-title');
          if (movieTitleEl) movieTitleEl.textContent = data.title;

          if (data.trailerKey) {
            const link = document.getElementById('trailer-link');
            if (link) {
              link.classList.remove('hidden');
              link.innerHTML = `<a href="https://www.youtube.com/watch?v=${data.trailerKey}" target="_blank" rel="noopener noreferrer nofollow" class="text-blue-400 text-sm hover:underline">Watch Trailer on YouTube</a>`;
            }
          }

          if (type === 'tv' && data.seasons > 0) {
            const tc = document.getElementById('tv-controls');
            if (tc && seasonSelect) {
              tc.classList.remove('hidden');
              seasonSelect.innerHTML = Array.from({ length: data.seasons }, (_, i) =>
                `<option value="${i + 1}" ${i + 1 === season ? 'selected' : ''}>Season ${i + 1}</option>`
              ).join('');
              episodeSelect.innerHTML = Array.from({ length: 20 }, (_, i) =>
                `<option value="${i + 1}" ${i + 1 === episode ? 'selected' : ''}>Episode ${i + 1}</option>`
              ).join('');
            }
          }
        } else {
          setState('error', 'metadata');
        }
      })
      .catch(() => setState('error', 'metadata'));

    if (firstVisit) {
      populateChooser();
      setState('chooser');
    } else {
      loadPlayer(currentServerIdx);
    }
  } else {
    setState('error', 'metadata');
  }
</script>
