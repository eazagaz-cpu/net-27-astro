---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import { SITE_URL } from '../lib/seo';
import { APK_UNIVERSAL_URL } from '../lib/constants';
---

<BaseLayout>
  <SEOHead slot="head" title="Watch | NetMirror" description="Watch movies and shows on NetMirror." canonical={`${SITE_URL}/player/`} noindex={true} />

  <main class="min-h-screen bg-black text-white">
    <div class="fixed top-0 left-0 right-0 z-50 bg-black/90 backdrop-blur-sm border-b border-white/5">
      <div class="flex items-center justify-between px-4 h-12">
        <button onclick="history.back()" class="flex items-center gap-2 text-sm text-zinc-400 hover:text-white cursor-pointer">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          Back
        </button>
        <h1 class="text-sm font-medium truncate max-w-[50%]" id="player-title">Loading...</h1>
        <div class="flex items-center gap-2">
          <select id="server-select" class="bg-white/10 text-xs text-white border border-white/10 rounded px-2 py-1 cursor-pointer">
            <option value="1">Server 1</option>
            <option value="2">Server 2</option>
          </select>
          <a href="/" class="p-1 text-zinc-400 hover:text-white" aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </a>
        </div>
      </div>
    </div>

    <div id="tv-controls" class="fixed top-12 left-0 right-0 z-40 bg-black/80 border-b border-white/5 px-4 py-2 hidden">
      <div class="flex items-center gap-3 max-w-[1400px] mx-auto">
        <select id="season-select" class="bg-white/10 text-xs text-white border border-white/10 rounded px-2 py-1 cursor-pointer"></select>
        <select id="episode-select" class="bg-white/10 text-xs text-white border border-white/10 rounded px-2 py-1 cursor-pointer"></select>
      </div>
    </div>

    <div class="pt-12 flex flex-col items-center justify-center min-h-screen">
      <div class="text-center px-4 max-w-lg">
        <h2 class="text-xl font-bold mb-2">Choose a server</h2>
        <p class="text-sm text-zinc-400 mb-6">Server 1 recommended · Server 2 is a fallback</p>
        <div class="flex items-center justify-center gap-4 mb-8">
          <button class="px-8 py-3 rounded-xl text-sm font-semibold text-white cursor-pointer transition-all hover:scale-105" style="background: var(--color-primary);">Server 1</button>
          <button class="px-8 py-3 rounded-xl text-sm font-semibold text-white cursor-pointer border border-white/15 hover:bg-white/5 transition-all">Server 2</button>
        </div>
        <div class="glass-card rounded-2xl p-6 text-left mb-6">
          <p class="text-sm text-zinc-400 mb-4">Streaming source is not configured for this title. Use the NetMirror app for the best experience.</p>
          <div class="flex flex-wrap gap-3">
            <a href={APK_UNIVERSAL_URL} download class="btn-primary text-xs px-4 py-2 rounded-lg" rel="noopener noreferrer">⬇ Download App</a>
            <button onclick="history.back()" class="btn-glass text-xs px-4 py-2 rounded-lg cursor-pointer">More Info</button>
          </div>
        </div>
        <p id="trailer-link" class="hidden mb-4"></p>
        <p class="text-[10px] text-zinc-600">NetMirror does not host any content. Streams are provided by third-party services.</p>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const type = params.get('type') || 'movie';
  const id = params.get('id') || '';
  if (type && id) {
    fetch(`/api/tmdb/details?type=${type}&id=${id}`)
      .then(r => r.json())
      .then(data => {
        if (data.title) {
          const el = document.getElementById('player-title');
          if (el) el.textContent = data.title;
          document.title = `Watch ${data.title} | NetMirror`;
          if (data.trailerKey) {
            const link = document.getElementById('trailer-link');
            if (link) { link.classList.remove('hidden'); link.innerHTML = `<a href="https://www.youtube.com/watch?v=${data.trailerKey}" target="_blank" rel="noopener" class="text-[var(--color-accent)] text-sm hover:underline">▶ Watch Official Trailer on YouTube</a>`; }
          }
          if (type === 'tv' && data.seasons > 0) {
            const tc = document.getElementById('tv-controls');
            const ss = document.getElementById('season-select');
            if (tc && ss) { tc.classList.remove('hidden'); ss.innerHTML = Array.from({length: data.seasons}, (_, i) => `<option value="${i+1}">Season ${i+1}</option>`).join(''); }
          }
        }
      }).catch(() => {});
  }
</script>
