---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';
import Schema from '../../components/Schema.astro';
import TitleCard from '../../components/TitleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { sampleTitles, getRelatedTitles } from '../../data/sampleTitles';
import { breadcrumbSchema, tvSeriesSchema, faqSchema } from '../../lib/schema';
import { SITE_URL } from '../../lib/seo';

export const getStaticPaths = (() => {
  return sampleTitles
    .filter(t => t.type === 'show' || t.type === 'anime')
    .map(title => ({
      params: { slug: title.slug },
      props: { title },
    }));
}) satisfies GetStaticPaths;

const { title } = Astro.props;
const related = getRelatedTitles(title);
const isAnime = title.type === 'anime';
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'TV Shows', href: '/shows/' },
  { label: title.title, href: `/shows/${title.slug}/` },
];
const faqs = [
  { question: `Where can I watch ${title.title}?`, answer: `${title.title} is available on ${title.platforms.join(', ')}.` },
  { question: `What is ${title.title} about?`, answer: title.overview },
  { question: `Who stars in ${title.title}?`, answer: `The cast includes ${title.cast.map(c => c.name).join(', ')}.` },
];

const placeholderGradients = [
  'from-red-900/80 to-purple-900/80',
  'from-blue-900/80 to-indigo-900/80',
  'from-emerald-900/80 to-teal-900/80',
  'from-orange-900/80 to-red-900/80',
  'from-violet-900/80 to-fuchsia-900/80',
  'from-cyan-900/80 to-blue-900/80',
  'from-rose-900/80 to-pink-900/80',
  'from-amber-900/80 to-yellow-900/80',
];
const gradient = placeholderGradients[title.title.length % placeholderGradients.length];

const posterGradients = [
  'from-red-900 to-purple-900',
  'from-blue-900 to-indigo-900',
  'from-emerald-900 to-teal-900',
  'from-orange-900 to-red-900',
  'from-violet-900 to-fuchsia-900',
  'from-cyan-900 to-blue-900',
  'from-rose-900 to-pink-900',
  'from-amber-900 to-yellow-900',
];
const posterGradient = posterGradients[title.title.length % posterGradients.length];

const schemaData = [
  tvSeriesSchema({
    title: title.title,
    overview: title.overview,
    poster_path: title.poster,
    first_air_date: title.releaseDate,
    genre: title.genres,
    number_of_seasons: title.seasons,
  }),
  breadcrumbSchema(breadcrumbs),
  faqSchema(faqs),
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={`Watch ${title.title} (${title.year}) - Stream Online`}
    description={`${title.title} (${title.year}) - ${title.overview.slice(0, 150)}... Find where to watch ${title.title} online on ${title.platforms.join(', ')}.`}
    canonical={`${SITE_URL}/shows/${title.slug}/`}
    ogType="video.tv_show"
  />
  <Schema slot="head" schema={schemaData} />

  <Header />

  <main>
    <!-- Backdrop Hero Area -->
    <section class="relative w-full min-h-[60vh] md:min-h-[70vh] overflow-hidden">
      <!-- Gradient Backdrop -->
      <div class={`absolute inset-0 bg-gradient-to-br ${gradient}`}></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(124,58,237,0.15),transparent_70%)]"></div>

      <!-- Dark Overlay Gradients -->
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-primary)] via-[var(--color-bg-primary)]/60 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-bg-primary)]/80 to-transparent"></div>

      <!-- Content Overlay -->
      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-8">
        <Breadcrumbs items={breadcrumbs} />

        <div class="flex flex-col md:flex-row gap-8 mt-4">
          <!-- Poster -->
          <div class="flex-shrink-0 w-48 md:w-64">
            <div class={`aspect-[2/3] rounded-xl overflow-hidden shadow-2xl bg-gradient-to-br ${posterGradient} flex items-center justify-center`}>
              <span class="text-7xl md:text-8xl font-bold text-white/20 select-none">
                {title.title.charAt(0).toUpperCase()}
              </span>
            </div>
          </div>

          <!-- Info -->
          <div class="flex-1 flex flex-col justify-end">
            <div class="flex items-center gap-3 mb-3">
              {isAnime && (
                <span class="px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-wider bg-[var(--color-accent)]/20 text-[var(--color-accent)] border border-[var(--color-accent)]/30">
                  Anime
                </span>
              )}
              {!isAnime && (
                <span class="px-3 py-1 rounded-lg text-xs font-bold uppercase tracking-wider bg-[var(--color-accent-alt)]/20 text-[var(--color-accent-alt)] border border-[var(--color-accent-alt)]/30">
                  TV Series
                </span>
              )}
            </div>

            <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-4">
              {title.title}
            </h1>

            <!-- Meta Row -->
            <div class="flex flex-wrap items-center gap-3 mb-4">
              <span class="text-[var(--color-text-secondary)] font-medium">{title.year}</span>
              <span class="w-1 h-1 rounded-full bg-[var(--color-text-muted)]"></span>
              <span class="text-[var(--color-text-secondary)]">{title.runtime} / ep</span>
              <span class="w-1 h-1 rounded-full bg-[var(--color-text-muted)]"></span>
              <span class="flex items-center gap-1 text-yellow-400 font-semibold">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                </svg>
                {title.rating.toFixed(1)}
              </span>
              {title.quality && (
                <span class="px-2.5 py-1 rounded text-xs font-bold uppercase tracking-wider bg-[var(--color-primary)] text-white">
                  {title.quality}
                </span>
              )}
              <span class="px-2.5 py-1 rounded text-xs font-medium bg-white/10 text-[var(--color-text-secondary)]">
                {title.status}
              </span>
            </div>

            <!-- Seasons & Episodes -->
            <div class="flex flex-wrap items-center gap-4 mb-5">
              {title.seasons && (
                <div class="flex items-center gap-2 glass-card rounded-lg px-4 py-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--color-accent)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                  </svg>
                  <span class="text-white font-medium text-sm">{title.seasons} {title.seasons === 1 ? 'Season' : 'Seasons'}</span>
                </div>
              )}
              {title.episodes && (
                <div class="flex items-center gap-2 glass-card rounded-lg px-4 py-2">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--color-accent-alt)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z" />
                  </svg>
                  <span class="text-white font-medium text-sm">{title.episodes} Episodes</span>
                </div>
              )}
            </div>

            <!-- Genre Chips -->
            <div class="flex flex-wrap gap-2 mb-5">
              {title.genres.map(genre => (
                <a href={`/genre/${genre.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}/`} class="chip text-sm">
                  {genre}
                </a>
              ))}
            </div>

            <!-- Director / Creator -->
            <p class="text-[var(--color-text-secondary)] mb-4">
              <span class="text-[var(--color-text-muted)]">{isAnime ? 'Director' : 'Created by'}</span>
              <span class="text-white font-medium ml-1">{title.director}</span>
            </p>

            <!-- Overview -->
            <p class="text-[var(--color-text-secondary)] leading-relaxed max-w-3xl text-base md:text-lg">
              {title.overview}
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Content Sections -->
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 space-y-16">

      <!-- Cast Section -->
      <section>
        <h2 class="section-title mb-6">Cast</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
          {title.cast.map(member => (
            <div class="glass-card rounded-xl p-4 text-center">
              <div class="w-16 h-16 mx-auto mb-3 rounded-full bg-gradient-to-br from-[var(--color-primary)]/30 to-[var(--color-accent)]/30 flex items-center justify-center">
                <span class="text-xl font-bold text-white/60">{member.name.charAt(0)}</span>
              </div>
              <p class="text-sm font-semibold text-white truncate">{member.name}</p>
              <p class="text-xs text-[var(--color-text-muted)] truncate mt-1">{member.role}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- Where to Watch -->
      <section>
        <h2 class="section-title mb-6">Where to Watch</h2>
        <div class="flex flex-wrap gap-3">
          {title.platforms.map(platform => (
            <a
              href={`/platform/${platform.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}/`}
              class="glass-card rounded-xl px-6 py-4 flex items-center gap-3 hover:border-[var(--color-primary)] transition-colors duration-200"
            >
              <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-[var(--color-accent)]/40 to-[var(--color-accent-alt)]/40 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <span class="text-white font-medium">{platform}</span>
            </a>
          ))}
        </div>
        <p class="mt-4 text-xs text-[var(--color-text-muted)]">
          Availability may vary by region. Check each platform for current streaming options.
        </p>
      </section>

      <!-- Trailer Section -->
      <section>
        <h2 class="section-title mb-6">Trailer</h2>
        {title.trailerUrl ? (
          <div class="aspect-video rounded-xl overflow-hidden glass-card">
            <iframe
              src={title.trailerUrl}
              title={`${title.title} Trailer`}
              class="w-full h-full"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        ) : (
          <div class="glass-card rounded-xl p-12 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-16 h-16 mx-auto mb-4 text-[var(--color-text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
            <p class="text-[var(--color-text-muted)] text-lg">Trailer coming soon</p>
            <p class="text-[var(--color-text-muted)] text-sm mt-2">Check back later for the official trailer.</p>
          </div>
        )}
      </section>

      <!-- FAQ Section -->
      <section>
        <h2 class="section-title mb-6">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {faqs.map((faq, index) => (
            <details class="glass-card rounded-xl group" open={index === 0}>
              <summary class="flex items-center justify-between cursor-pointer p-5 text-white font-medium hover:text-[var(--color-primary)] transition-colors duration-200 list-none">
                <span>{faq.question}</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-text-muted)] group-open:rotate-180 transition-transform duration-200 flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-5 pb-5 text-[var(--color-text-secondary)] leading-relaxed border-t border-[var(--color-border)] pt-4">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </section>

      <!-- Related Titles -->
      {related.length > 0 && (
        <section>
          <h2 class="section-title mb-6">You Might Also Like</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
            {related.map(relatedTitle => (
              <TitleCard title={relatedTitle} />
            ))}
          </div>
        </section>
      )}

      <!-- Legal Disclaimer -->
      <section class="glass-card rounded-xl p-6">
        <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
          <strong class="text-[var(--color-text-secondary)]">Disclaimer:</strong> Net27 does not host, store, or distribute any copyrighted content. All information provided on this page, including show details, cast, and streaming availability, is for informational purposes only. We help users discover titles and find legal streaming options. All trademarks, service marks, and content referenced belong to their respective owners. Streaming availability may vary by region and is subject to change.
        </p>
      </section>

    </div>
  </main>

  <Footer />
</BaseLayout>
