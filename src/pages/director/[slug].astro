---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';
import Schema from '../../components/Schema.astro';
import TitleCard from '../../components/TitleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { directors, getDirectorTitles, actors } from '../../data/entities';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';
import { SITE_URL } from '../../lib/seo';

export const getStaticPaths = (() => {
  return directors.map(director => ({
    params: { slug: director.slug },
    props: { director },
  }));
}) satisfies GetStaticPaths;

const { director } = Astro.props;
const titles = getDirectorTitles(director);

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Directors', href: '/' },
  { label: director.name, href: `/director/${director.slug}/` },
];

// Find actors who appear in this director's titles
const actorNamesInTitles = new Set(titles.flatMap(t => t.cast.map(c => c.name)));
const relatedActors = actors.filter(a => actorNamesInTitles.has(a.name));

// Collect unique genres from the director's titles
const directorGenres = [...new Set(titles.flatMap(t => t.genres))];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: director.name,
  description: director.bio,
  birthDate: String(director.birthYear),
  nationality: director.nationality,
  jobTitle: 'Director',
  url: `${SITE_URL}/director/${director.slug}/`,
};

const faqs = [
  { question: `What has ${director.name} directed?`, answer: `${director.name} has directed ${titles.length} titles in our database, including ${titles.slice(0, 3).map(t => t.title).join(', ')}. Explore the complete filmography below.` },
  { question: `What is ${director.name}'s directing style?`, answer: `${director.style} This distinctive approach has earned ${director.name} recognition across the industry.` },
  { question: `Where is ${director.name} from?`, answer: `${director.name} is ${director.nationality}, born in ${director.birthYear}. They have built a distinguished career in the international film and television industry.` },
  { question: `Which actors has ${director.name} worked with?`, answer: `${director.name} has collaborated with talented actors including ${relatedActors.slice(0, 4).map(a => a.name).join(', ')}. See the full list of collaborators on this page.` },
  { question: `Where can I watch ${director.name}'s films and shows?`, answer: `${director.name}'s titles are available across major streaming platforms. Visit each title page for specific platform availability and streaming options.` },
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={`${director.name} - Filmography`}
    description={`Explore ${director.name}'s filmography including ${titles.length} directed titles. ${director.bio.split('.')[0]}.`}
    canonical={`${SITE_URL}/director/${director.slug}/`}
  />
  <Schema slot="head" schema={[breadcrumbSchema(breadcrumbs), faqSchema(faqs), personSchema]} />

  <Header />

  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-accent)]/10 to-[var(--color-accent-alt)]/10"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-primary)] to-transparent"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-8">
        <Breadcrumbs items={breadcrumbs} />

        <div class="mt-4 mb-2">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight">
            <span class="gradient-text">{director.name}</span> - Filmography
          </h1>
          <div class="mt-4 flex flex-wrap gap-3">
            <span class="chip">{director.nationality}</span>
            <span class="chip">Born {director.birthYear}</span>
            <span class="chip">Director</span>
          </div>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 space-y-16">

      <!-- Bio & Style Section -->
      <section class="glass-card rounded-xl p-8">
        <h2 class="section-title mb-4">Biography</h2>
        <p class="text-[var(--color-text-secondary)] text-lg leading-relaxed mb-6">{director.bio}</p>
        <h3 class="text-white font-semibold text-lg mb-2">Directing Style</h3>
        <p class="text-[var(--color-text-secondary)] leading-relaxed">{director.style}</p>
      </section>

      <!-- Filmography -->
      <section>
        <h2 class="section-title mb-6">Directed Titles ({titles.length})</h2>
        {titles.length > 0 ? (
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
            {titles.map(title => (
              <TitleCard title={title} />
            ))}
          </div>
        ) : (
          <div class="glass-card rounded-xl p-12 text-center">
            <p class="text-[var(--color-text-muted)] text-lg">No titles found for this director.</p>
          </div>
        )}
      </section>

      <!-- FAQs -->
      <section>
        <h2 class="section-title mb-6">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {faqs.map(faq => (
            <details class="glass-card rounded-xl p-6 group">
              <summary class="cursor-pointer text-white font-semibold text-lg flex items-center justify-between">
                {faq.question}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-text-muted)] group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-4 text-[var(--color-text-secondary)] leading-relaxed">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- Actors in Director's Films -->
      {relatedActors.length > 0 && (
        <section>
          <h2 class="section-title mb-6">Actors in {director.name}'s Films</h2>
          <div class="flex flex-wrap gap-3">
            {relatedActors.map(a => (
              <a href={`/actor/${a.slug}/`} class="chip">
                {a.name}
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Related Genres -->
      {directorGenres.length > 0 && (
        <section>
          <h2 class="section-title mb-6">Explore Genres</h2>
          <div class="flex flex-wrap gap-3">
            {directorGenres.map(g => (
              <a href={`/genre/${g.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}/`} class="chip">
                {g}
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Legal Disclaimer -->
      <section class="glass-card rounded-xl p-6">
        <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
          <strong class="text-[var(--color-text-secondary)]">Disclaimer:</strong> Net27 does not host, store, or distribute any copyrighted content. All information provided on this page is for informational purposes only. We help users discover titles and find legal streaming options. All trademarks, service marks, and content referenced belong to their respective owners.
        </p>
      </section>

    </div>
  </main>

  <Footer />
</BaseLayout>
