---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';
import Schema from '../../components/Schema.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import FAQSection from '../../components/FAQSection.astro';
import DynamicGrid from '../../components/DynamicGrid.tsx';
import { genres, languages, platforms } from '../../data/sampleTitles';
import { getAllBlogPosts } from '../../data/blogPosts';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';
import { SITE_URL } from '../../lib/seo';

export const getStaticPaths = (() => {
  return genres.map(genre => ({
    params: { slug: genre.slug },
    props: { genre },
  }));
}) satisfies GetStaticPaths;

const { genre } = Astro.props;
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Genres', href: '/' },
  { label: genre.name, href: `/genre/${genre.slug}/` },
];
const relatedGenres = genres.filter(g => g.slug !== genre.slug);
const relatedPosts = getAllBlogPosts()
  .filter(p => p.tags?.some(t => t.toLowerCase().includes(genre.name.toLowerCase()) || t.toLowerCase().includes(genre.slug)))
  .slice(0, 3);
const genreDescriptions: Record<string, string> = {
  'Action': 'Action titles deliver adrenaline-pumping sequences, intense stunts, and high-stakes conflict. From explosive blockbusters to martial arts epics, this genre keeps viewers on the edge of their seats with relentless pacing and visceral thrills. Whether it\'s a lone hero fighting against impossible odds or a team assembling for a critical mission, action stories celebrate courage, determination, and spectacular set pieces.',
  'Comedy': 'Comedy titles bring laughter and levity through witty dialogue, absurd situations, and memorable characters. Ranging from sharp satirical commentary to feel-good romcoms, comedies provide essential entertainment that helps us see the humor in everyday life. The best comedies balance laughs with genuine heart, creating stories that entertain while also delivering surprising emotional depth.',
  'Drama': 'Drama titles explore the complexity of human experience through powerful storytelling and nuanced character development. This genre encompasses everything from intimate character studies to sweeping historical epics, united by their focus on authentic emotional truth. Great dramas challenge viewers to empathize with characters facing difficult choices, moral dilemmas, and transformative life events.',
  'Horror': 'Horror titles tap into our deepest fears through suspense, atmosphere, and the unknown. From psychological terror to supernatural nightmares, this genre explores the dark corners of human experience. The best horror films use fear as a lens to examine societal anxieties, personal trauma, and the boundaries between reality and nightmare.',
  'Romance': 'Romance titles celebrate love in all its forms, from passionate first encounters to enduring partnerships tested by time. These stories explore attraction, vulnerability, and the transformative power of genuine connection. Whether set in exotic locales or everyday neighborhoods, romance titles remind us that love stories are among the most universal and compelling narratives in cinema.',
  'Sci-Fi': 'Science fiction titles push the boundaries of imagination, exploring futuristic technologies, alien civilizations, and alternate realities. From hard science speculation to space opera adventures, sci-fi uses speculative concepts to examine present-day issues through a futuristic lens. The genre challenges viewers to consider what might be possible and how technology shapes the human condition.',
  'Thriller': 'Thriller titles build tension through suspense, mystery, and psychological complexity. These stories keep audiences guessing with unpredictable plot twists, unreliable narrators, and high-stakes situations where every decision matters. From espionage dramas to psychological cat-and-mouse games, thrillers deliver gripping entertainment that demands full attention.',
  'Fantasy': 'Fantasy titles transport viewers to extraordinary worlds filled with magic, mythical creatures, and epic quests. From high fantasy kingdoms to urban supernatural settings, this genre invites audiences to escape into realms where anything is possible. The best fantasy stories use their fantastical elements to explore timeless themes of heroism, sacrifice, and the battle between good and evil.',
  'Animation': 'Animation titles showcase the limitless potential of visual storytelling, using artistry and technology to create worlds that live-action cannot. From hand-drawn classics to cutting-edge CGI, animated works span every genre and audience, proving that animation is a medium, not just a children\'s genre. The best animated titles combine stunning visuals with stories that resonate across all ages.',
  'Documentary': 'Documentary titles illuminate real-world stories, people, and events through carefully crafted narratives and investigative journalism. This genre reveals hidden truths, celebrates remarkable achievements, and challenges conventional wisdom. From nature documentaries to true crime investigations, these titles educate, inspire, and provoke thoughtful discussion.',
  'Mystery': 'Mystery titles invite viewers to piece together clues alongside detectives, investigators, and amateur sleuths. The genre thrives on suspense, misdirection, and the satisfaction of solving a puzzle. From classic whodunits to modern procedurals, mystery stories test our powers of observation and deduction while delivering compelling character-driven narratives.',
  'Crime': 'Crime titles explore the world of law enforcement, criminal enterprise, and justice from every angle. Whether following detectives hunting serial killers or examining the inner workings of organized crime, this genre examines the thin line between order and chaos. Crime stories often serve as mirrors to society, revealing systemic issues while delivering gripping, tension-filled entertainment.',
  'Adventure': 'Adventure titles take characters and audiences on thrilling journeys through uncharted territories, dangerous landscapes, and extraordinary challenges. The genre celebrates exploration, discovery, and the human spirit\'s drive to push beyond known boundaries. From treasure hunts to survival stories, adventure titles deliver excitement while showcasing the beauty and danger of the wider world.',
  'Family': 'Family titles bring generations together with stories that entertain, educate, and inspire audiences of all ages. These titles balance humor, heart, and wholesome themes without talking down to younger viewers or boring older ones. The best family content creates shared experiences that spark conversation and create lasting memories.',
};
const description = genreDescriptions[genre.name] || `Explore the best ${genre.name.toLowerCase()} movies, TV shows, and anime available for streaming. Discover critically acclaimed titles and hidden gems in this genre across all major platforms.`;

const faqs = [
  { question: `Where can I stream ${genre.name} movies and shows?`, answer: `${genre.name} titles are available across multiple streaming platforms including Netflix, Prime Video, Disney+, Hulu, Apple TV+, and more. Each title page shows specific platform availability so you can find where to watch legally.` },
  { question: `What makes a great ${genre.name.toLowerCase()} movie?`, answer: `Great ${genre.name.toLowerCase()} titles combine strong storytelling, compelling characters, and expert craftsmanship. The best entries in this genre push boundaries while honoring the conventions that fans love, creating experiences that resonate long after the credits roll.` },
  { question: `Is the ${genre.name.toLowerCase()} collection updated regularly?`, answer: `Yes, our ${genre.name.toLowerCase()} catalog is refreshed regularly with new releases and trending titles across movies, TV shows, and anime.` },
  { question: `Are there ${genre.name.toLowerCase()} anime series available?`, answer: `Yes — anime offers unique perspectives on the ${genre.name.toLowerCase()} genre with distinctive animation styles and storytelling approaches. Browse the collection above to see current ${genre.name.toLowerCase()} anime titles.` },
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={`Best ${genre.name} Movies & Shows to Watch Free Online (${new Date().getFullYear()})`}
    description={`Discover ${genre.name.toLowerCase()} movies, TV shows, and anime. Watch the best ${genre.name.toLowerCase()} titles free online on NetMirror — no sign-up required.`}
    canonical={`${SITE_URL}/genre/${genre.slug}/`}
  />
  <Schema slot="head" schema={[breadcrumbSchema(breadcrumbs), faqSchema(faqs)]} />

  <Header />

  <main class="min-h-screen">
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-primary)]/10 to-[var(--color-accent)]/10"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-primary)] to-transparent"></div>
      <div class="relative z-10 mx-auto max-w-7xl px-4 pt-24 pb-10">
        <Breadcrumbs items={breadcrumbs} />
        <h1 class="mt-4 text-3xl sm:text-4xl md:text-5xl font-extrabold leading-tight">
          <span class="gradient-text">{genre.name}</span> Movies & Shows
        </h1>
        <p class="mt-4 text-[var(--color-text-secondary)] text-lg max-w-3xl">
          Explore {genre.name.toLowerCase()} titles across movies, TV shows, and anime. Find where to watch them on your favorite streaming platforms.
        </p>
      </div>
    </section>

    <div class="mx-auto max-w-7xl px-4 py-12 space-y-16">

      <section>
        <p class="text-[var(--color-text-secondary)] leading-relaxed max-w-4xl">{description}</p>
      </section>

      <section>
        <h2 class="section-title mb-6">All {genre.name} Titles</h2>
        <DynamicGrid client:idle category={genre.slug} title={genre.name} />
      </section>

      <section>
        <h2 class="section-title mb-6">Explore Other Genres</h2>
        <div class="flex flex-wrap gap-3">
          {relatedGenres.map(g => (
            <a href={`/genre/${g.slug}/`} class="chip">{g.name}</a>
          ))}
        </div>
      </section>

      <section>
        <h2 class="section-title mb-6">Browse by Language</h2>
        <div class="flex flex-wrap gap-3">
          {languages.slice(0, 8).map(l => (
            <a href={`/language/${l.slug}/`} class="chip">
              {l.name}
            </a>
          ))}
        </div>
      </section>

      <section>
        <h2 class="section-title mb-6">Browse by Platform</h2>
        <div class="flex flex-wrap gap-3">
          {platforms.map(p => (
            <a href={`/platform/${p.slug}/`} class="chip">
              {p.name}
            </a>
          ))}
        </div>
      </section>

      {relatedPosts.length > 0 && (
        <section>
          <h2 class="section-title mb-6">From the Blog</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {relatedPosts.map(post => (
              <a href={`/blog/${post.slug}/`} class="glass-card rounded-xl p-5 hover:border-[var(--color-primary)]/40 transition-all group">
                <span class="text-xs font-medium text-[var(--color-primary)] uppercase tracking-wider">{post.category}</span>
                <h3 class="mt-2 text-base font-semibold text-[var(--color-text-primary)] group-hover:text-[var(--color-primary)] transition-colors line-clamp-2">{post.title}</h3>
                <p class="mt-2 text-sm text-[var(--color-text-muted)] line-clamp-2">{post.excerpt}</p>
                <div class="mt-3 flex items-center gap-2 text-xs text-[var(--color-text-muted)]">
                  <span>{post.readTime}</span>
                  <span>&middot;</span>
                  <time>{post.date}</time>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <FAQSection faqs={faqs} />

      <section class="glass-card rounded-xl p-6">
        <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
          <strong class="text-[var(--color-text-secondary)]">Disclaimer:</strong> Net27 does not host, store, or distribute any copyrighted content. All information is for discovery and informational purposes only. All trademarks belong to their respective owners. Last updated: {new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}.
        </p>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>
