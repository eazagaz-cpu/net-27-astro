---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';
import Schema from '../../components/Schema.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import DynamicGrid from '../../components/DynamicGrid.tsx';
import { breadcrumbSchema } from '../../lib/schema';
import { SITE_URL } from '../../lib/seo';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Latest Releases', href: '/latest/' },
];
---

<BaseLayout>
  <SEOHead slot="head" title="New Releases — Latest Movies & Shows Added Today" description="Latest movie and show releases. New titles added daily across Netflix, Prime Video, Disney+, Crunchyroll." canonical={`${SITE_URL}/latest/`} />
  <Schema slot="head" schema={breadcrumbSchema(breadcrumbs)} />
  <Header />
  <main class="min-h-screen pt-20">
    <div class="max-w-[1400px] mx-auto px-4 py-8">
      <Breadcrumbs items={breadcrumbs} />
      <h1 class="text-3xl md:text-4xl font-bold mb-2">🆕 Latest Releases</h1>
      <p class="text-[var(--color-muted)] mb-8">Newest movies and TV shows released across all streaming platforms.</p>
      <DynamicGrid client:load category="latest" title="Latest Releases" />
    </div>
  </main>
  <Footer />
</BaseLayout>
