---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';
import Schema from '../../components/Schema.astro';
import TitleCard from '../../components/TitleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getLatestTitles } from '../../data/sampleTitles';
import { breadcrumbSchema } from '../../lib/schema';
import { SITE_URL } from '../../lib/seo';

const latest = getLatestTitles();
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Latest Releases', href: '/latest/' },
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="Latest Releases"
    description="Stay up to date with the newest movies, TV shows, and anime releases. Find the latest additions across Netflix, Prime Video, Disney+, and all major streaming platforms."
    canonical={`${SITE_URL}/latest/`}
  />
  <Schema slot="head" schema={breadcrumbSchema(breadcrumbs)} />

  <Header />

  <main class="min-h-screen pt-20">
    <div class="max-w-7xl mx-auto px-4 py-8">
      <Breadcrumbs items={breadcrumbs} />

      <h1 class="text-3xl md:text-4xl font-bold mb-8">Latest Releases</h1>

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 md:gap-6">
        {latest.map(title => <TitleCard title={title} />)}
      </div>

      {latest.length === 0 && (
        <div class="text-center py-16">
          <p class="text-[var(--color-text-muted)] text-lg">No latest releases found.</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>
