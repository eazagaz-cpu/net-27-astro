---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';
import Schema from '../../components/Schema.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getAllBlogPosts } from '../../data/blogPosts';
import { breadcrumbSchema } from '../../lib/schema';
import { SITE_URL } from '../../lib/seo';

const posts = getAllBlogPosts();
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
];

const placeholderGradients = [
  'from-red-900 to-purple-900',
  'from-blue-900 to-indigo-900',
  'from-emerald-900 to-teal-900',
  'from-orange-900 to-red-900',
  'from-violet-900 to-fuchsia-900',
  'from-cyan-900 to-blue-900',
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="Blog - Movie & Streaming News"
    description="Read the latest articles about movies, TV shows, anime, and streaming platforms. Expert insights, reviews, and industry analysis."
    canonical={`${SITE_URL}/blog/`}
  />
  <Schema slot="head" schema={breadcrumbSchema(breadcrumbs)} />

  <Header />

  <main class="min-h-screen pt-20">
    <div class="max-w-7xl mx-auto px-4 py-8">
      <Breadcrumbs items={breadcrumbs} />

      <h1 class="text-3xl md:text-4xl font-bold mb-2">Blog</h1>
      <p class="text-[var(--color-text-secondary)] mb-10">Latest news, guides, and insights about movies, shows, and streaming.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post, i) => (
          <a href={`/blog/${post.slug}/`} class="glass-card group rounded-xl overflow-hidden hover:border-[var(--color-primary)]/50 transition-all duration-300">
            <div class={`aspect-video bg-gradient-to-br ${placeholderGradients[i % placeholderGradients.length]} flex items-center justify-center`}>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-white/20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
            </div>
            <div class="p-5">
              <div class="flex items-center gap-3 mb-3 text-xs text-[var(--color-text-muted)]">
                <time>{post.date}</time>
                <span>&middot;</span>
                <span>{post.readTime}</span>
              </div>
              <h2 class="text-lg font-bold mb-2 group-hover:text-[var(--color-primary)] transition-colors line-clamp-2">
                {post.title}
              </h2>
              <p class="text-sm text-[var(--color-text-secondary)] line-clamp-3 mb-4">
                {post.excerpt}
              </p>
              <div class="flex flex-wrap gap-2">
                {post.tags.slice(0, 3).map(tag => (
                  <span class="text-[10px] px-2 py-0.5 rounded-full bg-[var(--color-bg-card)] text-[var(--color-text-muted)] border border-[var(--color-border)]">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
