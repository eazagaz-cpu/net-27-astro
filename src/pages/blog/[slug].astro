---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';
import Schema from '../../components/Schema.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { blogPosts, getAllBlogPosts } from '../../data/blogPosts';
import { breadcrumbSchema, articleSchema } from '../../lib/schema';
import { SITE_URL } from '../../lib/seo';

export const getStaticPaths = (() => {
  return blogPosts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}) satisfies GetStaticPaths;

const { post } = Astro.props;
const allPosts = getAllBlogPosts().filter(p => p.slug !== post.slug);
const relatedPosts = allPosts.slice(0, 3);

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: post.title, href: `/blog/${post.slug}/` },
];

---

<BaseLayout>
  <SEOHead
    slot="head"
    title={post.title}
    description={post.excerpt}
    canonical={`${SITE_URL}/blog/${post.slug}/`}
    ogType="article"
  />
  <Schema slot="head" schema={[
    breadcrumbSchema(breadcrumbs),
    articleSchema({ title: post.title, excerpt: post.excerpt, datePublished: post.date, author: post.author, image: post.image })
  ]} />

  <Header />

  <main class="min-h-screen pt-20">
    <article class="max-w-4xl mx-auto px-4 py-8">
      <Breadcrumbs items={breadcrumbs} />

      <header class="mb-10">
        <div class="flex flex-wrap gap-2 mb-4">
          {post.tags.map(tag => (
            <span class="chip text-xs">{tag}</span>
          ))}
        </div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4 leading-tight">
          {post.title}
        </h1>
        <div class="flex items-center gap-4 text-sm text-[var(--color-text-muted)]">
          <span>By {post.author}</span>
          <span>&middot;</span>
          <time>{post.date}</time>
          <span>&middot;</span>
          <span>{post.readTime}</span>
        </div>
      </header>

      <div class="aspect-video rounded-xl overflow-hidden mb-10">
        <img
          src={post.image}
          alt={post.title}
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>

      <div class="space-y-6 text-[var(--color-text-secondary)] text-lg leading-relaxed">
        {post.content.split('\n\n').map(paragraph => (
          <p>{paragraph}</p>
        ))}
      </div>

      <footer class="mt-12 pt-8 border-t border-[var(--color-border)]">
        <div class="flex flex-wrap gap-2 mb-8">
          {post.tags.map(tag => (
            <span class="chip text-xs">{tag}</span>
          ))}
        </div>

        {relatedPosts.length > 0 && (
          <div>
            <h2 class="section-title mb-6">Related Articles</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              {relatedPosts.map((related) => (
                <a href={`/blog/${related.slug}/`} class="glass-card rounded-lg p-5 hover:border-[var(--color-primary)]/50 transition-all">
                  <h3 class="font-semibold mb-2 line-clamp-2 hover:text-[var(--color-primary)] transition-colors">
                    {related.title}
                  </h3>
                  <p class="text-sm text-[var(--color-text-muted)]">{related.readTime}</p>
                </a>
              ))}
            </div>
          </div>
        )}
      </footer>
    </article>
  </main>

  <Footer />
</BaseLayout>
