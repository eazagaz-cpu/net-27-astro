---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';
import Schema from '../../components/Schema.astro';
import TitleCard from '../../components/TitleCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { years, getTitlesByYear } from '../../data/entities';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';
import { SITE_URL } from '../../lib/seo';

export const getStaticPaths = (() => {
  return years.map(y => ({
    params: { slug: y.slug },
    props: { year: y },
  }));
}) satisfies GetStaticPaths;

const { year } = Astro.props;
const titles = getTitlesByYear(year.year);
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Years', href: '/' },
  { label: String(year.year), href: `/year/${year.slug}/` },
];

const otherYears = years.filter(y => y.slug !== year.slug);

const faqs = [
  { question: `What are the best movies and shows from ${year.year}?`, answer: `Our top-rated titles from ${year.year} include ${titles.slice(0, 3).map(t => t.title).join(', ')}. Browse the full collection to discover more.` },
  { question: `How many titles were released in ${year.year}?`, answer: `We currently have ${titles.length} titles from ${year.year} in our database, spanning movies, TV shows, and anime.` },
  { question: `Where can I watch ${year.year} releases?`, answer: `Titles from ${year.year} are available across platforms including Netflix, Prime Video, Disney+, and more. Check each title page for specific availability.` },
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={`Best Movies & Shows of ${year.year} - Stream Online`}
    description={`Discover the best movies, TV shows, and anime from ${year.year}. Browse ${titles.length} titles and find where to watch them legally on streaming platforms.`}
    canonical={`${SITE_URL}/year/${year.slug}/`}
  />
  <Schema slot="head" schema={[breadcrumbSchema(breadcrumbs), faqSchema(faqs)]} />

  <Header />

  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-primary)]/10 to-[var(--color-accent)]/10"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-primary)] to-transparent"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-8">
        <Breadcrumbs items={breadcrumbs} />

        <div class="mt-4 mb-2">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight">
            Best Movies & Shows of <span class="gradient-text">{year.year}</span>
          </h1>
          <p class="mt-4 text-[var(--color-text-secondary)] text-lg max-w-2xl">
            Explore the standout films, series, and anime that defined {year.year}. From critically acclaimed dramas to crowd-pleasing blockbusters, discover {titles.length} titles worth watching from this year.
          </p>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 space-y-16">

      <!-- Results Count -->
      <div class="flex items-center justify-between">
        <p class="text-[var(--color-text-secondary)]">
          <span class="text-white font-semibold">{titles.length}</span> titles from {year.year}
        </p>
      </div>

      <!-- Titles Grid -->
      {titles.length > 0 ? (
        <section>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
            {titles.map(title => (
              <TitleCard title={title} />
            ))}
          </div>
        </section>
      ) : (
        <section class="glass-card rounded-xl p-12 text-center">
          <p class="text-[var(--color-text-muted)] text-lg">No titles found for this year.</p>
        </section>
      )}

      <!-- FAQs -->
      <section>
        <h2 class="section-title mb-6">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {faqs.map(faq => (
            <details class="glass-card rounded-xl p-6 group">
              <summary class="cursor-pointer text-white font-semibold text-lg flex items-center justify-between">
                {faq.question}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-text-muted)] group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-4 text-[var(--color-text-secondary)] leading-relaxed">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- Other Years -->
      <section>
        <h2 class="section-title mb-6">Browse by Year</h2>
        <div class="flex flex-wrap gap-3">
          {otherYears.map(y => (
            <a href={`/year/${y.slug}/`} class="chip">
              {y.year}
              <span class="ml-1 text-[var(--color-text-muted)]">({y.count})</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Legal Disclaimer -->
      <section class="glass-card rounded-xl p-6">
        <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
          <strong class="text-[var(--color-text-secondary)]">Disclaimer:</strong> Net27 does not host, store, or distribute any copyrighted content. All information provided on this page is for informational purposes only. We help users discover titles and find legal streaming options. All trademarks, service marks, and content referenced belong to their respective owners.
        </p>
      </section>

    </div>
  </main>

  <Footer />
</BaseLayout>
