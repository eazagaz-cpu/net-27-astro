---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';
import Schema from '../../components/Schema.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import DynamicGrid from '../../components/DynamicGrid.tsx';
import { countries } from '../../data/entities';
import { breadcrumbSchema, faqSchema } from '../../lib/schema';
import { SITE_URL } from '../../lib/seo';

export const getStaticPaths = (() => {
  return countries.map(country => ({
    params: { slug: country.slug },
    props: { country },
  }));
}) satisfies GetStaticPaths;

const { country } = Astro.props;
const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Countries', href: '/' },
  { label: country.name, href: `/country/${country.slug}/` },
];
const otherCountries = countries.filter(c => c.slug !== country.slug);

const faqs = [
  { question: `What is ${country.name} known for in cinema?`, answer: `${country.description}` },
  { question: `Where can I watch movies from ${country.name}?`, answer: `Titles from ${country.name} are available across streaming platforms including Netflix, Prime Video, Disney+, Crunchyroll, and more. Check each title page for specific availability.` },
];
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={`Movies & Shows from ${country.name} - Stream Online`}
    description={`Discover the best movies, TV shows, and anime from ${country.name}. Browse titles and find where to watch them legally on streaming platforms.`}
    canonical={`${SITE_URL}/country/${country.slug}/`}
  />
  <Schema slot="head" schema={[breadcrumbSchema(breadcrumbs), faqSchema(faqs)]} />

  <Header />

  <main>
    <!-- Hero Section -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-primary)]/10 to-[var(--color-accent)]/10"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-bg-primary)] to-transparent"></div>

      <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-12 pb-8">
        <Breadcrumbs items={breadcrumbs} />

        <div class="mt-4 mb-2">
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-white leading-tight">
            Movies & Shows from <span class="gradient-text">{country.name}</span>
          </h1>
          <p class="mt-4 text-[var(--color-text-secondary)] text-lg max-w-2xl">
            {country.description}
          </p>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 space-y-16">

      <!-- Titles Grid -->
      <section>
        <DynamicGrid client:idle category={`country-${country.slug}`} title={country.name} />
      </section>

      <!-- FAQs -->
      <section>
        <h2 class="section-title mb-6">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {faqs.map(faq => (
            <details class="glass-card rounded-xl p-6 group">
              <summary class="cursor-pointer text-white font-semibold text-lg flex items-center justify-between">
                {faq.question}
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-text-muted)] group-open:rotate-180 transition-transform flex-shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-4 text-[var(--color-text-secondary)] leading-relaxed">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- Other Countries -->
      <section>
        <h2 class="section-title mb-6">Explore Other Countries</h2>
        <div class="flex flex-wrap gap-3">
          {otherCountries.map(c => (
            <a href={`/country/${c.slug}/`} class="chip">{c.name}</a>
          ))}
        </div>
      </section>

      <!-- Legal Disclaimer -->
      <section class="glass-card rounded-xl p-6">
        <p class="text-xs text-[var(--color-text-muted)] leading-relaxed">
          <strong class="text-[var(--color-text-secondary)]">Disclaimer:</strong> Net27 does not host, store, or distribute any copyrighted content. All information provided on this page is for informational purposes only. We help users discover titles and find legal streaming options. All trademarks, service marks, and content referenced belong to their respective owners.
        </p>
      </section>

    </div>
  </main>

  <Footer />
</BaseLayout>
