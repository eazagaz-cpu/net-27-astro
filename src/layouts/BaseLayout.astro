---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://image.tmdb.org" />
  <link rel="preconnect" href="https://www.2embed.cc" />
  <link rel="preconnect" href="https://autoembed.co" />
  <link rel="dns-prefetch" href="https://image.tmdb.org" />
  <link rel="dns-prefetch" href="https://www.2embed.cc" />
  <link rel="dns-prefetch" href="https://autoembed.co" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <slot name="head" />
  <script is:inline>
    // Block unwanted popups and redirects from embed iframes
    (function() {
      var origOpen = window.open;
      window.open = function(url, target, features) {
        // Block if it looks like an ad popup
        if (!url || url === '' || url === 'about:blank') return null;
        if (typeof url === 'string' && (url.includes('click') || url.includes('track') || url.includes('ad') || url.includes('pop'))) return null;
        return origOpen.call(window, url, target, features);
      };
      // Prevent beforeunload hijack
      window.addEventListener('beforeunload', function(e) {
        if (document.querySelector('#player-iframe, #player-container')) {
          e.stopImmediatePropagation();
        }
      }, true);
    })();
  </script>
</head>
<body class="min-h-screen bg-[var(--color-bg-primary)] text-[var(--color-text-primary)] antialiased">
  <slot />
</body>
</html>
